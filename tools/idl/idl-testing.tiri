-- Unit tests for IDL types and parsing

   include 'core'
   include 'xml'

   import './include/utils'
   import './include/parser'
   import './include/functions'
   import './include/types'
   import './include/doc'

   glHeader = array<string>
   glOutput = array<string>
   glConstants = { }

   glSelf = obj.find('self')
   glCustomTypes.XIF = { list = {}, prefix='XIF' }

   local param_list = {
      { str = "int Width: The width of the image in pixels.", type='int', name='Width', t_type='num' },
      { str = "str Format: The format of the image, e.g., 'RGB', 'RGBA'.", type='str', name='Format', t_type='str' },
      { str = "obj(XML) XML: Target XML object.", type='obj(XML)', name='XML', t_type='obj' },
      { str = "ptr(func) Callback: Optional callback.", type="ptr(func)", name='Callback', t_type='func' },
      { str = "cstr Key: Keyname.", type="cstr", name='Key', t_type='str' },
      { str = "int(XIF) ResultFlags: Bitmask.", type='int(XIF)', name='ResultFlags', t_type='num' },
      { str = "ptr(cpp(str)) Result: Result.", type='ptr(cpp(str))', name='Result', t_type='any' },
      { str = "char(64) Label: Label buffer.", type='char(64)', name='Label', t_type='array' },
      { str = "double(4) Matrix: Matrix values.", type='double(4)', name='Matrix', t_type='array' }
   }

   for k, v in ipairs(param_list) do
      print('Check: ' .. v.str)
      local param = parseParameterString(v.str)

      assert(param.type is v.type, "Type mismatch for parameter '" .. v.name .. "': expected '" .. v.type .. "', got '" .. param.type .. "'")
      assert(param.name is v.name, "Name mismatch for parameter: expected '" .. v.name .. "', got '" .. param.name .. "'")

      cType(param, name)
      assert(param.fullType.t_type is v.t_type, "Tiri type mismatch for parameter '" .. v.name .. "': expected '" ..
         v.t_type .. "', got '" .. tostring(param.fullType.t_type) .. "'")
   end
