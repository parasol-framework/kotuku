{
   "name": "tiri-language",
   "displayName": "Tiri Language Support",
   "description": "Language support for Tiri programs",
   "version": "0.1.0",
   "publisher": "kotuku",
   "repository": {
      "type": "git",
      "url": "https://github.com/kotuku-group/kotuku.git",
      "directory": "tools/tiri_lsp/vscode_plugin"
   },
   "icon": "images/tiri.png",
   "engines": {
      "vscode": "^1.75.0"
   },
   "categories": [
      "Programming Languages"
   ],
   "activationEvents": [
      "onLanguage:tiri"
   ],
   "main": "./dist/extension.js",
   "scripts": {
      "bundle": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
      "vscode:prepublish": "npm run bundle"
   },
   "contributes": {
      "commands": [
         {
            "command": "tiri.restartLsp",
            "title": "Tiri: Restart Language Server"
         }
      ],
      "languages": [
         {
            "id": "tiri",
            "aliases": ["Tiri", "tiri"],
            "extensions": [".tiri"],
            "configuration": "./language-configuration.json"
         }
      ],
      "grammars": [
         {
            "language": "tiri",
            "scopeName": "source.tiri",
            "path": "./syntaxes/tiri.tmLanguage.json"
         }
      ],
      "configuration": {
         "type": "object",
         "title": "Tiri",
         "properties": {
            "tiri.lsp.enable": {
               "type": "boolean",
               "default": true,
               "description": "Enable Tiri LSP server connection"
            },
            "tiri.lsp.host": {
               "type": "string",
               "default": "127.0.0.1",
               "description": "LSP server host address"
            },
            "tiri.lsp.port": {
               "type": "number",
               "default": 5007,
               "description": "LSP server port. Set to 0 to run the server over stdio."
            },
            "tiri.lsp.autoStart": {
               "type": "boolean",
               "default": false,
               "description": "Automatically start the Tiri LSP server when connecting over TCP to a local host"
            },
            "tiri.lsp.origoPath": {
               "type": "string",
               "default": "origo",
               "description": "Path to the origo executable used when auto-starting the Tiri LSP server"
            },
            "tiri.lsp.serverScript": {
               "type": "string",
               "default": "tools/tiri_lsp/server.tiri",
               "description": "Path to the Tiri LSP server script used when auto-starting the server. Relative paths are resolved from the first workspace folder."
            },
            "tiri.lsp.logApi": {
               "type": "boolean",
               "default": false,
               "description": "Enable Origo/Core API logging for the Tiri LSP server. In stdio mode, logs are written to tiri.lsp.logFile or tiri-lsp-core.log in the workspace."
            },
            "tiri.lsp.logFile": {
               "type": "string",
               "default": "",
               "description": "Optional host file path for Origo/Core log output from the Tiri LSP server."
            }
         }
      },
      "semanticTokenScopes": [
         {
            "language": "tiri",
            "scopes": {
               "keyword": ["keyword.control.tiri"],
               "operator": ["keyword.operator.tiri"],
               "variable": ["variable.other.tiri"],
               "function": ["entity.name.function.tiri"],
               "string": ["string.quoted.tiri"],
               "number": ["constant.numeric.tiri"],
               "comment": ["comment.tiri"],
               "type": ["entity.name.type.tiri"],
               "parameter": ["variable.parameter.tiri"],
               "property": ["variable.other.property.tiri"],
               "namespace": ["entity.name.namespace.tiri"],
               "class": ["entity.name.class.tiri"],
               "macro": ["constant.other.tiri"]
            }
         }
      ],
      "configurationDefaults": {
         "[tiri]": {
            "editor.semanticHighlighting.enabled": true
         }
      }
   },
   "dependencies": {
      "vscode-languageclient": "^9.0.1"
   },
   "devDependencies": {
      "@types/vscode": "^1.75.0",
      "esbuild": "^0.25.0"
   }
}
