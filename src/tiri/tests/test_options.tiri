-- Flute tests for the first-party command-line options library.

   include 'core'
   import 'options'

function expect_error(Parser:table, Input:any, Code:num, MessagePart:str):table
   local args, err = Parser.tryProcess(Input)
   assert(args is nil, 'Expected parsing to fail')
   assert(err != nil, 'Expected a structured error')
   assert(err.code is Code, f"Expected error code '{Code}', got '{err.code}'")
   if MessagePart != nil then
      assert(err.message:find(MessagePart), f"Expected error message to include '{MessagePart}', got '{err.message}'")
   end
   assert(type(err.message) is 'string', 'Error should include a message')
   return err
end

function expect_error_with_options(Parser:table, Input:any, Options:table, Code:num, MessagePart:str):table
   local args, err = Parser.tryProcess(Input, Options)
   assert(args is nil, 'Expected parsing to fail')
   assert(err != nil, 'Expected a structured error')
   assert(err.code is Code, f"Expected error code '{Code}', got '{err.code} {err.message}'")
   if MessagePart != nil then
      assert(err.message:find(MessagePart), f"Expected error message to include '{MessagePart}', got '{err.message}'")
   end
   return err
end

function expect_validate_error(Parser:table, Args:table, Code:num, MessagePart:str):table
   try
      Parser.validate(Args)
   except err
      assert(err.code is Code, f"Expected error code '{Code}', got '{err.code} {err.message}'")
      if MessagePart != nil then
         assert(err.message:find(MessagePart),
            f"Expected error message to include '{MessagePart}', got '{err.message}'")
      end
      return err
   end

   error('Expected validation to fail')
end

function expect_options_error(Config:table, Code:num, MessagePart:str):table
   try
      options(Config)
   except err
      assert(err.code is Code, f"Expected error code '{Code}', got '{err.code} {err.message}'")
      if MessagePart != nil then
         assert(err.message:find(MessagePart),
            f"Expected error message to include '{MessagePart}', got '{err.message}'")
      end
      return err
   end

   error('Expected parser construction to fail')
end

function set_test_env(Name:str, Value:any)
   task = processing.task()
   err = task.mtSetEnv(Name, Value)
   assert(err is ERR_Okay, f"Failed to set environment variable '{Name}': {mSys.GetErrorMsg(err)}")
end

-----------------------------------------------------------------------------------------------------------------------

@Test function ConstructEmptyParser()
   parser = options({})
   local args = parser.process(array<string> { })
   assert(type(args) is 'table', 'Empty parser should process to a table')
end

@Test function NamedOptionsAndAliases()
   parser = options({
      name        = 'vuepoint',
      description = 'Viewer',
      epilog      = 'Done',
      copyright   = 'Copyright',
      license     = 'MIT',
      args = array<table> {
         { name = 'file', kind = 'option', type = 'file' },
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool' }
      }
   })

   local args = parser.process(array<string> { 'file=scene.svg', 'v' })
   assert(args.file is 'scene.svg', 'Named option should parse')
   assert(args.verbose is true, 'Flag alias should parse')
   assert(parser.getParam('verbose').name is 'verbose', 'Canonical parameter lookup should work')
   assert(parser.getParam('v').name is 'verbose', 'Alias parameter lookup should work')
end

@Test function DuplicateAliasesFail()
   try
      options({
         args = array<table> {
            { names = array<string> { 'file', 'f' } },
            { names = array<string> { 'folder', 'f' } }
         }
      })
   except e
      assert(tostring(e.message):find("Duplicate parameter name or alias 'f'"),
         'Duplicate alias diagnostic should be reported')
      return
   end

   error('Duplicate aliases should throw')
end

@Test function DuplicateAliasesWithinDefinitionFail()
   try
      options({ args = array<table> { { names = array<string> { 'file', 'file' } } } })
   except e
      assert(tostring(e.message):find("Duplicate parameter name or alias 'file'"),
         'Duplicate aliases inside one definition should be reported')
      return
   end

   error('Duplicate aliases inside one definition should throw')
end

@Test function AddParamRejectsDuplicates()
   parser = options({ args = array<table> { { name = 'file' } } })

   try
      parser.addParam({ names = array<string> { 'folder', 'file' } })
   except e
      assert(tostring(e.message):find("Duplicate parameter name or alias 'file'"),
         'Duplicate addParam() diagnostic should be reported')
      return
   end

   error('addParam() should reject duplicate names')
end

@Test function DefaultsAndRequired()
   parser = options({
      args = array<table> {
         { name = 'count', type = 'int', default = '7', required = true },
         { name = 'output', type = 'path', required = true }
      }
   })

   expect_error(parser, array<string> { }, ERR_ParameterRequired, "Required parameter 'output' is missing.")

   local args = parser.process(array<string> { 'output=build/result.txt' })
   assert(args.count is 7, 'String defaults should be converted')
   assert(args.output is 'build/result.txt', 'Required option should parse')
end

@Test function FalseyDefaults()
   parser = options({
      args = array<table> {
         { name = 'enabled', type = 'bool', default = false },
         { name = 'count', type = 'int', default = 0 },
         { name = 'label', type = 'str', default = '' }
      }
   })

   local args = parser.process(array<string> { })
   assert(args.enabled is false, 'False default should be applied')
   assert(args.count is 0, 'Zero default should be applied')
   assert(args.label is '', 'Empty string default should be applied')

   args = parser.process(array<string> { 'enabled' })
   assert(args.enabled is false, 'Bare option should use a false default when one exists')
end

@Test function OptionSyntax()
   parser = options({
      args = array<table> {
         { name = 'enabled', type = 'bool' },
         { name = 'mode', default = 'auto' }
      }
   })

   expect_error(parser, array<string> { 'enabled' }, ERR_Syntax, "Parameter 'enabled' requires name=value syntax.")

   local args = parser.process(array<string> { 'enabled=true', 'mode' })
   assert(args.enabled is true, 'Boolean option should accept explicit values')
   assert(args.mode is 'auto', 'Bare option should use its default when one exists')
end

@Test function FlagSyntax()
   parser = options({
      args = array<table> {
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool', default = false },
         { name = 'dry-run', kind = 'flag', type = 'bool' }
      }
   })

   local args = parser.process(array<string> { 'verbose', 'no-dry-run' })
   assert(args.verbose is true, 'Bare flag should parse as true')
   assert(args['dry-run'] is false, 'no- flag should parse as false')

   args = parser.process(array<string> { 'v=0' })
   assert(args.verbose is false, 'Explicit flag values should use boolean conversion')
end

@Test function NegationOnlyAppliesToFlags()
   parser = options({ args = array<table> { { name = 'feature' } } })
   expect_error(parser, array<string> { 'no-feature' }, ERR_Args,
      "Parameter 'feature' is not a flag and cannot use no- negation.")
end

@Test function UnknownParametersRespectStrictMode()
   strict_parser = options({ args = array<table> { { name = 'file' } } })
   err = expect_error(strict_parser, array<string> { 'extra=value' }, ERR_ParameterUnknown,
      "Unknown parameter 'extra'.")
   assert(err.message:find('stack traceback') is nil, 'Unknown named parameters should not include a stack trace')

   loose_parser = options({ strict = false, args = array<table> { { name = 'file', default = 'fallback.txt' } } })
   args = loose_parser.process(array<string> { 'extra=value' })
   assert(args.file is 'fallback.txt', 'strict=false should ignore unknown named input')
end

@Test function BuiltInConverters()
   parser = options({
      args = array<table> {
         { name = 'title', type = 'string' },
         { name = 'ratio', type = 'number' },
         { name = 'count', type = 'int' },
         { name = 'enabled', type = 'bool' },
         { name = 'path', type = 'path' },
         { name = 'file', type = 'file' },
         { name = 'folder', type = 'folder' }
      }
   })

   args = parser.process(array<string> {
      'title=hello',
      'ratio=2.5',
      'count=4',
      'enabled=yes',
      'path=some/path',
      'file=scene.svg',
      'folder=examples'
   })

   assert(args.title is 'hello', 'String converter failed')
   assert(args.ratio is 2.5, 'Number converter failed')
   assert(args.count is 4, 'Integer converter failed')
   assert(args.enabled is true, 'Boolean converter failed')
   assert(args.path is 'some/path', 'Path converter failed')
   assert(args.file is 'scene.svg', 'File converter failed')
   assert(args.folder is 'examples', 'Folder converter failed')

   expect_error(parser, array<string> { 'count=4.5' }, ERR_WrongType, "Parameter 'count' requires an integer.")
   expect_error(parser, array<string> { 'enabled=maybe' }, ERR_WrongType,
      "Parameter 'enabled' requires a boolean value.")
end

@Test function CustomConverter()
   parser = options({
      args = array<table> {
         {
            name = 'label',
            type = function(RawValue:any, Definition:table, Parser:table):any
               assert(Definition.name is 'label', 'Definition should be passed to custom converter')
               assert(Parser.getParam('label') is Definition, 'Parser should be passed to custom converter')
               return 'custom:' .. tostring(RawValue)
            end
         },
         {
            name = 'fail',
            type = function(RawValue:any, Definition:table, Parser:table):any
               error('custom failure')
            end
         }
      }
   })

   args = parser.process(array<string> { 'label=value' })
   assert(args.label is 'custom:value', 'Custom converter should transform values')

   err = expect_error(parser, array<string> { 'fail=value' }, ERR_Exception, 'custom failure')
   assert(err.message:find('custom failure'), 'Thrown converter errors should be returned by tryProcess()')
end

@Test function TryProcessDoesNotUseFailurePath()
   parser = options({ args = array<table> { { name = 'file' } } })
   called = false
   parser.error = function(Error:any, ParamName:str)
      called = true
      error(Error)
   end

   args, err = parser.tryProcess(array<string> { 'unknown=value' })
   assert(args is nil, 'tryProcess() should return nil on parse failure')
   assert(err.code is ERR_ParameterUnknown, 'tryProcess() should return the parse error')
   assert(called is false, 'tryProcess() must not invoke parser.error()')
end

@Test function ProcessReturnsParsedArgs()
   parser = options({ args = array<table> { { name = 'file', required = true } } })
   called = false
   parser.error = function(Error:any, ParamName:str)
      called = true
      error(Error)
   end

   args = parser.process(array<string> { 'file=scene.svg' })
   assert(args.file is 'scene.svg', 'process() should return parsed arguments')
   assert(called is false, 'process() should not call parser.error() on success')
end

@Test function TableInput()
   parser = options({
      args = array<table> {
         { name = 'count', type = 'int' },
         { name = 'enabled', kind = 'flag', type = 'bool' }
      }
   })

   args = parser.process({ count = 3, enabled = false })
   assert(args.count is 3, 'Table input should accept typed values')
   assert(args.enabled is false, 'Table input should accept typed flag values')
end

@Test function PositionalOrdering()
   parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file', required = true },
         { name = 'output', kind = 'option', type = 'file' }
      }
   })

   args = parser.process(array<string> { 'scene.svg', 'output=preview.png' })
   assert(args.input is 'scene.svg', 'First positional should parse in declaration order')
   assert(args.output is 'preview.png', 'Named option should parse alongside positional input')
end

@Test function ExplicitInputBypassesTaskParameters()
   parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file' }
      }
   })

   args = parser.process(array<string> { 'explicit.svg' }, {
      taskParameters = array<string> { 'tools/flute.tiri', 'task.svg' }
   })

   assert(args.input is 'explicit.svg', 'Explicit input should take precedence over task parameters')
end

@Test function DefaultTaskParametersAreScannedAfterScriptPath()
   parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file' },
         { name = 'output', kind = 'option', type = 'file' },
         { name = 'verbose', kind = 'flag', type = 'bool' }
      }
   })

   args = parser.process(nil, {
      taskParameters = array<string> {
         '--log-warning',
         '--set-volume',
         'scripts=E:/kotuku/scripts',
         'examples/vue.tiri',
         'scene.svg',
         'output=preview.png',
         'verbose'
      }
   })

   assert(args.input is 'scene.svg', 'Default task input should begin after the script path')
   assert(args.output is 'preview.png', 'Named option after the script path should parse')
   assert(args.verbose is true, 'Flag after the script path should parse')
end

@Test function DefaultInputReadsCurrentTaskParameters()
   parser = options({ strict = false, args = array<table> { { name = 'file' } } })
   args = parser.process(nil)

   assert(args.file != nil, 'Default input should read the current Flute file parameter from the active task')
   assert(args.file:find('test_options.tiri'), 'Default input should expose the running test file argument')
end

@Test function ArgFallbackUsedWhenTaskParametersUnavailable()
   parser = options({ strict = false, args = array<table> { { name = 'file' } } })
   args = parser.process(nil, { taskParameters = false })

   assert(args.file != nil, 'arg() fallback should be used when ordered task input is unavailable')
   assert(args.file:find('test_options.tiri'), 'arg() fallback should expose the running test file argument')
end

@Test function PositionalUnavailableWithoutOrderedInput()
   parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional', required = true }
      }
   })

   expect_error_with_options(parser, nil, { taskParameters = false }, ERR_ParameterRequired,
      "Required parameter 'input' is missing.")
end

@Test function RepeatedNamedValues()
   parser = options({
      args = array<table> {
         { name = 'tag', type = 'int', multiple = true }
      }
   })

   local args = parser.process(array<string> { 'tag=1', 'tag=2' })
   assert(type(args.tag) is 'array', 'Repeated values should produce an array')
   assert(#args.tag is 2, 'Repeated values should preserve every occurrence')
   assert(args.tag[0] is 1, 'First repeated value should be converted')
   assert(args.tag[1] is 2, 'Second repeated value should be converted')
end

@Test function MultipleDefaultsAreArrayShaped()
   parser = options({
      args = array<table> {
         { name = 'single', type = 'int', multiple = true, default = '5' },
         { name = 'many', type = 'int', multiple = true, default = array<string> { '1', '2' } }
      }
   })

   local args = parser.process(array<string> { })
   assert(type(args.single) is 'array', 'Scalar multiple default should be wrapped in an array')
   assert(#args.single is 1, 'Scalar multiple default should produce one value')
   assert(args.single[0] is 5, 'Scalar multiple default should be converted')
   assert(#args.many is 2, 'Array multiple default should preserve every default value')
   assert(args.many[0] is 1 and args.many[1] is 2, 'Array multiple default should convert each value')
end

@Test function TableInputMultipleValues()
   parser = options({
      args = array<table> {
         { name = 'tag', type = 'int', multiple = true }
      }
   })

   local args = parser.process({ tag = array<string> { '3', '4' } })
   assert(#args.tag is 2, 'Programmatic array input should be treated as repeated values')
   assert(args.tag[0] is 3 and args.tag[1] is 4, 'Programmatic repeated values should be converted')
end

@Test function TrailingVariadicPositional()
   parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file' },
         { name = 'rest', kind = 'positional', type = 'str', multiple = true }
      }
   })

   args = parser.process(array<string> { 'scene.svg', 'one', 'two' })
   assert(args.input is 'scene.svg', 'Leading positional should receive the first value')
   assert(type(args.rest) is 'array', 'Variadic positional should produce an array')
   assert(#args.rest is 2, 'Variadic positional should consume remaining values')
   assert(args.rest[0] is 'one' and args.rest[1] is 'two', 'Variadic positional should preserve order')
end

@Test function InvalidVariadicPositionalDeclaration()
   try
      options({
         args = array<table> {
            { name = 'rest', kind = 'positional', multiple = true },
            { name = 'next', kind = 'positional' }
         }
      })
   except e
      assert(e.code is ERR_Syntax, 'Invalid variadic declaration should report a syntax error')
      assert(tostring(e.message):find("Variadic positional parameter 'rest' must be the final positional."),
         'Invalid variadic declaration should explain the ordering rule')
      return
   end

   error('Variadic positional definitions should be final')
end

@Test function StrictOrderedUnknownTokens()
   strict_parser = options({
      args = array<table> {
         { name = 'input', kind = 'positional' }
      }
   })

   err = expect_error(strict_parser, array<string> { 'scene.svg', 'extra.svg' }, ERR_ParameterUnknown,
      "Unknown parameter 'extra.svg'.")
   assert(err.message:find('stack traceback') is nil, 'Unknown positional parameters should not include a stack trace')

   loose_parser = options({
      strict = false,
      args = array<table> {
         { name = 'input', kind = 'positional' }
      }
   })

   args = loose_parser.process(array<string> { 'scene.svg', 'extra.svg' })
   assert(args.input is 'scene.svg', 'strict=false should ignore extra ordered tokens')
end

@Test function ParserDefaultsAndSetDefaults()
   parser = options({
      defaults = { count = '2', mode = 'parser' },
      args = array<table> {
         { name = 'count', type = 'int', default = '1' },
         { name = 'mode', type = 'str', default = 'param' }
      }
   })

   args = parser.process(array<string> { })
   assert(args.count is 2, 'Parser defaults should override parameter defaults')
   assert(args.mode is 'parser', 'Parser string defaults should apply')

   returned = parser.setDefaults({ count = '3' })
   assert(returned is parser, 'setDefaults() should return the parser')

   args = parser.process(array<string> { })
   assert(args.count is 3, 'setDefaults() should override parser defaults')
   assert(args.mode is 'parser', 'Parser defaults should remain below the setDefaults layer')

   args = parser.process(array<string> { 'count=4' })
   assert(args.count is 4, 'Explicit input should override every default layer')
end

@Test function EnvironmentLookupAndRequired()
   set_test_env('KOTUKU_OPTIONS_STAGE3_FILE', 'scene.svg')
   set_test_env('KOTUKU_OPTIONS_STAGE3_VERBOSE', 'yes')
   set_test_env('KOTUKU_OPTIONS_STAGE3_V', 'no')
   set_test_env('KOTUKU_OPTIONS_STAGE3_DRY_RUN', 'true')

   parser = options({
      envPrefix = 'KOTUKU_OPTIONS_STAGE3',
      args = array<table> {
         { name = 'file', type = 'file', required = true },
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool' },
         { name = 'dryRun', kind = 'flag', type = 'bool' }
      }
   })

   args = parser.process(array<string> { })
   assert(args.file is 'scene.svg', 'Environment values should satisfy required parameters')
   assert(args.verbose is true, 'Environment values should be converted')
   assert(args.dryRun is true, 'Camel-case names should be converted to upper snake-case environment names')

   set_test_env('KOTUKU_OPTIONS_STAGE3_FILE', nil)
   set_test_env('KOTUKU_OPTIONS_STAGE3_VERBOSE', nil)
   set_test_env('KOTUKU_OPTIONS_STAGE3_V', nil)
   set_test_env('KOTUKU_OPTIONS_STAGE3_DRY_RUN', nil)
end

@Test function SourcePrecedenceOrder()
   set_test_env('KOTUKU_OPTIONS_PRECEDENCE_COUNT', '4')

   parser = options({
      envPrefix = 'KOTUKU_OPTIONS_PRECEDENCE',
      defaults = { count = '2' },
      args = array<table> {
         { name = 'count', type = 'int', default = '1' }
      }
   })
   parser.setDefaults({ count = '3' })

   args = parser.process(array<string> { })
   assert(args.count is 4, 'Environment values should override all default layers')

   args = parser.process(array<string> { 'count=5' })
   assert(args.count is 5, 'Input values should override environment values')

   set_test_env('KOTUKU_OPTIONS_PRECEDENCE_COUNT', nil)
end

@Test function SourcePrecedenceDefersConversion()
   set_test_env('KOTUKU_OPTIONS_BAD_COUNT', 'bad')

   env_parser = options({
      envPrefix = 'KOTUKU_OPTIONS_BAD',
      args = array<table> {
         { name = 'count', type = 'int' }
      }
   })

   args = env_parser.process(array<string> { 'count=3' })
   assert(args.count is 3, 'Explicit input should override an invalid environment value before conversion')
   expect_error(env_parser, array<string> { }, ERR_WrongType, "Parameter 'count' requires an integer.")

   default_parser = options({
      defaults = { count = 'bad' },
      args = array<table> {
         { name = 'count', type = 'int' }
      }
   })

   args = default_parser.process(array<string> { 'count=4' })
   assert(args.count is 4, 'Explicit input should override an invalid default before conversion')
   expect_error(default_parser, array<string> { }, ERR_WrongType, "Parameter 'count' requires an integer.")

   set_test_env('KOTUKU_OPTIONS_BAD_COUNT', nil)
end

@Test function ChoicesEnumAndPatternValidation()
   parser = options({
      args = array<table> {
         { name = 'mode', type = 'enum', choices = array<string> { 'fast', 'slow' } },
         { name = 'tag', type = 'str', pattern = regex.new('^[a-z][a-z0-9_]+$') }
      }
   })

   args = parser.process(array<string> { 'mode=fast', 'tag=build_1' })
   assert(args.mode is 'fast', 'Enum values should parse as strings')
   assert(args.tag is 'build_1', 'Pattern-matching values should parse')

   expect_error(parser, array<string> { 'mode=medium' }, ERR_Args, "Parameter 'mode' must be one of: fast, slow.")
   expect_error(parser, array<string> { 'tag=1_bad' }, ERR_Args, "Parameter 'tag' does not match the required pattern.")

   try
      options({ args = array<table> { { name = 'bad', type = 'enum' } } })
   except e
      assert(e.code is ERR_Syntax, 'Enum without choices should fail as a syntax error')
      return
   end

   error('Enum parameters should require choices')
end

@Test function ExistingPathValidation()
   parser = options({
      args = array<table> {
         { name = 'path', type = 'path', exists = true },
         { name = 'file', type = 'file', exists = true },
         { name = 'folder', type = 'folder', exists = true }
      }
   })

   args = parser.process(array<string> {
      'path=scripts/options.tiri',
      'file=scripts/options.tiri',
      'folder=scripts'
   })
   assert(args.path is 'scripts/options.tiri', 'Existing path should parse')
   assert(args.file is 'scripts/options.tiri', 'Existing file should parse')
   assert(args.folder is 'scripts', 'Existing folder should parse')

   expect_error(parser, array<string> { 'path=does-not-exist' }, ERR_FileNotFound, "does not exist")
   expect_error(parser, array<string> { 'file=scripts' }, ERR_ExpectedFile, "is not a file")
   expect_error(parser, array<string> { 'folder=scripts/options.tiri' }, ERR_ExpectedFolder, "is not a folder")
end

@Test function MultipleValuesUseValidationRules()
   parser = options({
      args = array<table> {
         { name = 'level', type = 'int', multiple = true, choices = array<any> { 1, 2, 3 } }
      }
   })

   args = parser.process(array<string> { 'level=1', 'level=3' })
   assert(#args.level is 2, 'Repeated validated values should be preserved')
   assert(args.level[0] is 1 and args.level[1] is 3, 'Repeated values should be converted before validation')

   expect_error(parser, array<string> { 'level=4' }, ERR_Args, "Parameter 'level' must be one of: 1, 2, 3.")
end

@Test function RelationshipValidation()
   parser = options({
      args = array<table> {
         { name = 'output', requires = 'input' },
         { name = 'input' },
         { name = 'credentials', requiresAny = array<string> { 'user', 'token' } },
         { name = 'user' },
         { name = 'token' },
         { name = 'dry-run', kind = 'flag', excludes = 'write' },
         { name = 'write', kind = 'flag' }
      }
   })

   args = parser.process(array<string> { 'input=scene.svg', 'output=preview.png', 'credentials=x', 'token=abc' })
   assert(args.output is 'preview.png', 'requires should pass when the dependency is present')

   expect_error(parser, array<string> { 'output=preview.png' }, ERR_ParameterRequired,
      "Parameter 'output' requires 'input'.")
   expect_error(parser, array<string> { 'credentials=x' }, ERR_ParameterRequired,
      "Parameter 'credentials' requires one of: user, token.")
   expect_error(parser, array<string> { 'dry-run', 'write' }, ERR_Args, "Parameter 'dry-run' excludes 'write'.")
end

@Test function RelationshipValidationUsesExplicitPresence()
   parser = options({
      args = array<table> {
         { name = 'output', default = 'preview.png', requires = 'input' },
         { name = 'input' },
         { name = 'dry-run', kind = 'flag', type = 'bool', default = false, excludes = 'write' },
         { name = 'write', kind = 'flag', type = 'bool' }
      }
   })

   args = parser.process(array<string> { 'write' })
   assert(args.output is 'preview.png', 'Defaulted options should still be applied')
   assert(args['dry-run'] is false, 'Defaulted flags should still be applied')
   assert(args.write is true, 'Explicit flags should parse when excluded only by an unsupplied defaulted flag')

   expect_error(parser, array<string> { 'output=final.png' }, ERR_ParameterRequired,
      "Parameter 'output' requires 'input'.")
   expect_error(parser, array<string> { 'dry-run', 'write' }, ERR_Args, "Parameter 'dry-run' excludes 'write'.")
end

@Test function ExecReceivesParserArgValueAndDefinition()
   called = false
   seen_arg = nil
   seen_value = nil
   seen_definition = nil

   parser = options({
      args = array<table> {
         {
            names = array<string> { 'level', 'l' },
            type = 'int',
            exec = function(Parser:table, Arg:str, Value:any, Definition:table):any
               assert(Parser.getParam('level') is Definition, 'exec should receive the parser and definition')
               called = true
               seen_arg = Arg
               seen_value = Value
               seen_definition = Definition
            end
         }
      }
   })

   args = parser.process(array<string> { 'l=3' })
   assert(args.level is 3, 'exec should run after conversion')
   assert(called is true, 'exec should be called during validation')
   assert(seen_arg is 'l', 'exec should receive the original input argument name')
   assert(seen_value is 3, 'exec should receive the converted value')
   assert(seen_definition.name is 'level', 'exec should receive the canonical definition')
end

@Test function ValidateConvertsAndChecksCallerTables()
   parser = options({
      args = array<table> {
         { name = 'count', type = 'int', required = true },
         { name = 'mode', type = 'enum', choices = array<string> { 'fast', 'slow' } },
         { name = 'output', requires = 'mode' }
      }
   })

   args = parser.validate({ count = '7', mode = 'slow' })
   assert(args.count is 7, 'validate() should convert caller-supplied values')
   assert(args.mode is 'slow', 'validate() should return validated values')

   expect_validate_error(parser, { mode = 'fast' }, ERR_ParameterRequired, "Required parameter 'count' is missing.")
   expect_validate_error(parser, { count = '1', output = 'preview.png' }, ERR_ParameterRequired,
      "Parameter 'output' requires 'mode'.")
end

@Test function ValidationRunsAfterSourcePrecedence()
   parser = options({
      defaults = { mode = 'invalid' },
      args = array<table> {
         { name = 'mode', type = 'enum', choices = array<string> { 'fast', 'slow' } }
      }
   })

   args = parser.process(array<string> { 'mode=fast' })
   assert(args.mode is 'fast', 'Higher-precedence input should be the value that validation sees')

   expect_error(parser, array<string> { }, ERR_Args, "Parameter 'mode' must be one of: fast, slow.")
end

@Test function UsageAndNormalHelp()
   parser = options({
      name        = 'vuepoint',
      description = 'View vector documents',
      epilog      = 'End of help.',
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file', required = true, comment = 'Input document' },
         { names = array<string> { 'output', 'o' }, type = 'file', metavar = 'PATH', default = 'preview.png',
            comment = 'Output preview' },
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool', comment = 'Enable logs' }
      }
   })

   usage = parser.getUsage()
   assert(usage:find('Usage: vuepoint'), 'Usage should include the parser name')
   assert(usage:find('<INPUT>'), 'Usage should include required positionals')
   assert(usage:find('output=PATH'), 'Usage should include option metavars')

   help = parser.getHelp()
   assert(help:find('View vector documents'), 'Normal help should include the description')
   assert(help:find('Arguments:'), 'Normal help should group positional arguments')
   assert(help:find('Options:'), 'Normal help should group named options')
   assert(help:find('output=PATH, o=PATH'), 'Normal help should show aliases')
   assert(help:find('default: preview.png'), 'Normal help should show defaults')
   assert(help:find('verbose, v, no-verbose'), 'Normal help should show flag aliases and negation')
   assert(help:find('End of help.'), 'Normal help should include the epilog')
end

@Test function DetailedHelpAndHiddenParameters()
   parser = options({
      name = 'tool',
      args = array<table> {
         {
            names = array<string> { 'mode', 'm' },
            type = 'enum',
            choices = array<string> { 'fast', 'slow' },
            required = true,
            comment = 'Execution mode',
            description = 'Controls how much validation the tool performs.'
         },
         { name = 'token', hidden = true, comment = 'Secret token' }
      }
   })

   help = parser.getHelp()
   assert(help:find('mode=MODE'), 'Visible parameters should appear in normal help')
   assert(not help:find('token'), 'Hidden parameters should be excluded from normal help')

   detail = parser.getHelp(nil, 'm')
   assert(detail:find('mode:'), 'Detailed help should resolve aliases to canonical names')
   assert(detail:find('Execution mode'), 'Detailed help should include comments')
   assert(detail:find('Controls how much validation'), 'Detailed help should include descriptions')
   assert(detail:find('Aliases: m'), 'Detailed help should list aliases')
   assert(detail:find('Required: yes'), 'Detailed help should show required markers')
   assert(detail:find('Choices: fast, slow'), 'Detailed help should show choices')

   hidden_detail = parser.getHelp(nil, 'token')
   assert(hidden_detail:find('Secret token'), 'Hidden parameters should still support detailed help')
end

@Test function GroupedHelpOutput()
   parser = options({
      name = 'pack',
      args = array<table> {
         { name = 'input', group = 'Input', comment = 'Input path' },
         { name = 'output', group = 'Output', comment = 'Output path' }
      }
   })

   help = parser.getHelp()
   assert(help:find('Input:'), 'Custom input group should be rendered')
   assert(help:find('Output:'), 'Custom output group should be rendered')
   assert(help:find('Input path'), 'Grouped parameter comments should be rendered')
   assert(help:find('Output path'), 'Grouped parameter comments should be rendered')
end

@Test function AutomaticHelpHandling()
   parser = options({
      name = 'demo',
      args = array<table> {
         { name = 'file', type = 'file', required = true, comment = 'File to read' }
      }
   })

   result, err = parser.tryProcess(array<string> { 'help' })
   assert(err is nil, 'tryProcess() should not treat help as a parse failure')
   assert(result.help is true, 'tryProcess() should return a structured help result')
   assert(result.text:find('Usage: demo'), 'Structured help result should include normal help text')

   result, err = parser.tryProcess(array<string> { 'help=file' })
   assert(err is nil, 'tryProcess() should return detailed help without failing')
   assert(result.topic is 'file', 'Detailed help result should report the requested topic')
   assert(result.text:find('File to read'), 'Detailed help should be generated for help=argname')

   cli_parser = options({
      name = 'convert',
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file', required = true },
         { name = 'output', kind = 'option', type = 'file', required = true }
      }
   })

   result, err = cli_parser.tryProcess(nil, {
      taskParameters = array<string> { '--log-warning', 'test.tiri', 'help' }
   })
   assert(err is nil, 'Default task-parameter help should not validate required arguments')
   assert(result.help is true, 'Default task-parameter help should return a structured help result')
   assert(result.text:find('Usage: convert'), 'Default task-parameter help should include normal help text')

   result, err = cli_parser.tryProcess(nil, {
      taskParameters = array<string> { '--log-warning', 'test.tiri' }
   })
   assert(err is nil, 'Empty default task parameters should print help instead of validating required arguments')
   assert(result.help is true, 'Empty default task parameters should return a structured help result')
   assert(result.text:find('Usage: convert'), 'Empty default task parameter help should include normal help text')

   seen_text = nil
   seen_topic = nil
   help_parser = options({
      name = 'demo',
      onHelp = function(Parser:table, Text:str, Topic:any)
         assert(Parser.getParam('file') != nil, 'onHelp should receive the parser')
         seen_text = Text
         seen_topic = Topic
      end,
      args = array<table> {
         { name = 'file', type = 'file', comment = 'File to read' }
      }
   })

   returned = help_parser.process(array<string> { 'help=file' })
   assert(returned is nil, 'process() should not return normal args for help requests')
   assert(seen_topic is 'file', 'process() should pass the help topic to onHelp')
   assert(seen_text:find('File to read'), 'process() should pass generated help text to onHelp')
end

@Test function AutomaticHelpRejectsDeclaredHelpToken()
   expect_options_error({
      args = array<table> {
         { name = 'help', kind = 'positional', type = 'file', required = true }
      }
   }, ERR_DuplicateValue, "Parameter name or alias 'help' conflicts with automatic help; set autoHelp to false.")

   expect_options_error({
      args = array<table> {
         { name = 'help', type = 'str', required = true }
      }
   }, ERR_DuplicateValue, "Parameter name or alias 'help' conflicts with automatic help; set autoHelp to false.")

   expect_options_error({
      args = array<table> {
         { name = 'help', kind = 'flag', type = 'bool' }
      }
   }, ERR_DuplicateValue, "Parameter name or alias 'help' conflicts with automatic help; set autoHelp to false.")

   expect_options_error({
      args = array<table> {
         { names = array<string> { 'show-help', 'help' }, kind = 'flag', type = 'bool' }
      }
   }, ERR_DuplicateValue, "Parameter name or alias 'help' conflicts with automatic help; set autoHelp to false.")

   parser = options({})
   try
      parser.addParam({ name = 'help', kind = 'flag', type = 'bool' })
   except e
      assert(e.code is ERR_DuplicateValue, 'addParam() help collision should report a duplicate value')
      assert(e.message:find("Parameter name or alias 'help' conflicts with automatic help; set autoHelp to false."),
         'addParam() help collision diagnostic should explain the autoHelp requirement')
      return
   end

   error('addParam() should reject help parameters when automatic help is enabled')
end

@Test function ExplicitHelpBypassesRequiredValidationWhenAutoHelpDisabled()
   seen_text = nil
   seen_topic = nil
   parser = options({
      name = 'convert',
      autoHelp = false,
      onHelp = function(Parser:table, Text:str, Topic:any)
         seen_text = Text
         seen_topic = Topic
      end,
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file', required = true },
         { name = 'output', kind = 'option', type = 'file', required = true }
      }
   })

   returned = parser.process(array<string> { 'help' })
   assert(returned is nil, 'Explicit help should be handled before required validation')
   assert(seen_topic is nil, 'Bare help should request normal help')
   assert(seen_text:find('Usage: convert'), 'Explicit help should generate normal help text')

   result, err = parser.tryProcess(nil, {
      taskParameters = array<string> { '--log-warning', 'test.tiri', 'help' }
   })
   assert(err is nil, 'Task-parameter help should not validate required arguments')
   assert(result.help is true, 'Task-parameter help should return a structured help result')
   assert(result.text:find('Usage: convert'), 'Task-parameter help should include normal help text')

   result, err = parser.tryProcess(array<string> { 'help=output' })
   assert(err is nil, 'Help topics should not validate required arguments')
   assert(result.topic is 'output', 'Help should preserve explicit topics')
   assert(result.text:find('output:'), 'Help topics should generate detailed help text')

   positioned = options({
      autoHelp = false,
      args = array<table> {
         { name = 'input', kind = 'positional', required = true },
         { name = 'output', kind = 'positional', required = true }
      }
   })

   args = positioned.process(array<string> { 'abc', 'help' })
   assert(args.input is 'abc' and args.output is 'help', 'Manual help after another argument should parse normally')

   args = positioned.process(array<string> { 'help', 'abc' })
   assert(args.input is 'help' and args.output is 'abc', 'Manual help before another argument should parse normally')
end

@Test function DeclaredHelpParameterOverridesBuiltInHelpWhenAutoHelpDisabled()
   seen_text = nil
   seen_topic = nil
   parser = options({
      name = 'convert',
      autoHelp = false,
      onHelp = function(Parser:table, Text:str, Topic:any)
         seen_text = Text
         seen_topic = Topic
      end,
      args = array<table> {
         { name = 'input', kind = 'positional', type = 'file', required = true },
         { name = 'output', kind = 'option', type = 'file', required = true },
         { name = 'help', kind = 'flag', type = 'bool', comment = 'Show help.' }
      }
   })

   returned = parser.process(array<string> { 'help' })
   assert(returned is nil, 'Declared help should be handled before required validation')
   assert(seen_topic is nil, 'Declared bare help should request normal help')
   assert(seen_text:find('Usage: convert'), 'Declared help should generate normal help text')

   result, err = parser.tryProcess(array<string> { 'help=output' })
   assert(err is nil, 'Declared help topics should not validate required arguments')
   assert(result.topic is 'output', 'Declared help should preserve explicit topics')
   assert(result.text:find('output:'), 'Declared help topics should generate detailed help text')

   args = parser.process(array<string> { 'input.svg', 'output=preview.png', 'help' })
   assert(args.input is 'input.svg', 'Declared help after another argument should parse normally')
   assert(args.output is 'preview.png', 'Declared help should not consume neighbouring arguments')
   assert(args.help is true, 'Declared help after another argument should parse as the declared help flag')

   args = options({
      autoHelp = false,
      args = array<table> {
         { name = 'help', kind = 'flag', type = 'bool' }
      }
   }).process(array<string> { 'help=false' })
   assert(args.help is false, 'Declared help=false should parse instead of falling through to built-in help')
end

@Test function UnsupportedHelpFormatsFail()
   parser = options({
      args = array<table> {
         { name = 'file' }
      }
   })

   failed = false
   try
      parser.getHelp('html')
   except e
      assert(e.code is ERR_InvalidType, 'Unsupported help formats should report an invalid type error')
      assert(e.message:find("Unsupported help format 'html'."), 'Unsupported format message should be stable')
      failed = true
   end
   assert(failed is true, 'Unsupported help formats should fail')

   args, err = parser.tryProcess(array<string> { 'help=missing' })
   assert(args is nil, 'Unknown help topics should fail as structured errors')
   assert(err.code is ERR_ParameterUnknown, 'Unknown help topics should report parameter-unknown')
end

@Test function AutoHelpCanBeDisabled()
   disabled = options({
      name = 'viewer',
      autoHelp = false,
      args = array<table> {
         { name = 'file', required = true }
      }
   })

   result, err = disabled.tryProcess(array<string> { 'help' })
   assert(err is nil, 'Explicit help should still work when autoHelp is disabled')
   assert(result.help is true, 'Explicit help should return a structured help result')
   assert(result.text:find('Usage: viewer'), 'Explicit help should include normal help text')

   expect_error(disabled, array<string> { }, ERR_ParameterRequired, "Required parameter 'file' is missing.")
end

@Test function OnErrorInstructions()
   seen_arg = nil
   seen_raw = nil

   ignore_parser = options({
      onError = function(Parser:table, Error:table, Param:table, ArgName:str, RawValue:any):str
         assert(Param.name is 'count', 'onError should receive the rejected parameter')
         assert(Error.code is ERR_WrongType, 'onError should receive the conversion error')
         seen_arg = ArgName
         seen_raw = RawValue
         return 'ignore'
      end,
      args = array<table> {
         { name = 'count', type = 'int', default = '7' }
      }
   })

   args = ignore_parser.process(array<string> { 'count=bad' })
   assert(args.count is 7, 'onError ignore should fall back to the parameter default')
   assert(seen_arg is 'count', 'onError should receive the original argument name')
   assert(seen_raw is 'bad', 'onError should receive the rejected raw value')

   skip_parser = options({
      onError = function(Parser:table, Error:table, Param:table, ArgName:str, RawValue:any):str
         return 'skip'
      end,
      args = array<table> {
         { name = 'count', type = 'int', default = '7' }
      }
   })

   args = skip_parser.process(array<string> { 'count=bad' })
   assert(args.count is nil, 'onError skip should leave the parameter unset even when a default exists')

   fail_parser = options({
      onError = function(Parser:table, Error:table, Param:table, ArgName:str, RawValue:any):any
         return true
      end,
      args = array<table> {
         { name = 'count', type = 'int' }
      }
   })

   expect_error(fail_parser, array<string> { 'count=bad' }, ERR_WrongType,
      "Parameter 'count' requires an integer.")
end

@Test function OnErrorIgnoreRestoresRepeatedArrayDefaultsFlat()
   parser = options({
      onError = function(Parser:table, Error:table, Param:table, ArgName:str, RawValue:any):str
         return 'ignore'
      end,
      args = array<table> {
         {
            name     = 'tag',
            type     = 'array',
            multiple = true,
            default  = array<string> { 'fallback' },
            choices  = array<string> { 'fallback' }
         }
      }
   })

   args = parser.process(array<string> { 'tag=bad' })
   assert(type(args.tag) is 'array', 'Recovered array default should remain an array')
   assert(#args.tag is 1, 'Recovered array default should not be nested')
   assert(args.tag[0] is 'fallback', 'Recovered array default should keep the declared item')
end

@Test function CommandConstructionAliasesAndAddCommand()
   parser = options({
      commands = array<table> {
         {
            names = array<string> { 'build', 'b' },
            comment = 'Build the project',
            args = array<table> {
               { name = 'input', type = 'folder' }
            }
         }
      }
   })

   assert(parser.getCommand('build').name is 'build', 'Command lookup should accept canonical names')
   assert(parser.getCommand('b').name is 'build', 'Command lookup should accept aliases')
   assert(parser.getCommand('build').getParam('input').name is 'input',
      'Command parameters should be normalised and searchable')

   added = parser.addCommand({
      names = array<string> { 'test', 't' },
      args = array<table> {
         { name = 'filter' }
      }
   })

   assert(added.name is 'test', 'addCommand() should return the normalised command')
   assert(parser.getCommand('t') is added, 'addCommand() should register aliases')
   assert(added.getParam('filter').name is 'filter', 'addCommand() should register command parameters')
end

@Test function DuplicateCommandNamesFail()
   try
      options({
         commands = array<table> {
            { names = array<string> { 'build', 'b' } },
            { names = array<string> { 'bundle', 'b' } }
         }
      })
   except e
      assert(e.code is ERR_DuplicateValue, 'Duplicate command aliases should report a duplicate value')
      assert(e.message:find("Duplicate command name or alias 'b'"),
         'Duplicate command aliases should explain the conflict')
      return
   end

   error('Duplicate command aliases should fail')
end

@Test function CommandGlobalDispatchTokenCollisionsFail()
   expect_options_error({
      args = array<table> {
         { name = 'build', kind = 'flag', type = 'bool' }
      },
      commands = array<table> {
         { name = 'build' }
      }
   }, ERR_DuplicateValue, "Command name or alias 'build' conflicts with global parameter 'build'.")

   expect_options_error({
      args = array<table> {
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool' }
      },
      commands = array<table> {
         { names = array<string> { 'build', 'v' } }
      }
   }, ERR_DuplicateValue, "Command name or alias 'v' conflicts with global parameter 'v'.")

   expect_options_error({
      args = array<table> {
         { name = 'skip', kind = 'flag', type = 'bool' }
      },
      commands = array<table> {
         { name = 'no-skip' }
      }
   }, ERR_DuplicateValue, "Command name or alias 'no-skip' conflicts with global no- token 'no-skip'.")

   expect_options_error({
      commands = array<table> {
         { name = 'help' }
      }
   }, ERR_DuplicateValue, "Command name or alias 'help' conflicts with the reserved help token.")

   expect_options_error({
      autoHelp = false,
      commands = array<table> {
         { name = 'help' }
      }
   }, ERR_DuplicateValue, "Command name or alias 'help' conflicts with the reserved help token.")
end

@Test function LaterGlobalParamCannotHideCommand()
   parser = options({
      commands = array<table> {
         { name = 'build' }
      }
   })

   try
      parser.addParam({ name = 'build', kind = 'flag', type = 'bool' })
   except e
      assert(e.code is ERR_DuplicateValue, 'Global parameter collisions should report a duplicate value')
      assert(e.message:find("Parameter name or alias 'build' conflicts with command 'build'."),
         'Global parameter collisions should explain the command conflict')
      return
   end

   error('Global parameters should not be allowed to hide existing commands')
end

@Test function CommandDispatchAndResultShape()
   parser = options({
      args = array<table> {
         { names = array<string> { 'verbose', 'v' }, kind = 'flag', type = 'bool' }
      },
      commands = array<table> {
         {
            names = array<string> { 'build', 'b' },
            args = array<table> {
               { name = 'input', type = 'folder' },
               { name = 'release', kind = 'flag', type = 'bool' }
            }
         },
         {
            name = 'test',
            args = array<table> {
               { name = 'filter' }
            }
         }
      }
   })

   result = parser.process(array<string> { 'v', 'b', 'input=src', 'release' })
   assert(result.command is 'build', 'Command aliases should dispatch to the canonical name')
   assert(type(result.globals) is 'table', 'Command results should include global arguments')
   assert(type(result.args) is 'table', 'Command results should include command arguments')
   assert(result.globals.verbose is true, 'Global options before the command should parse')
   assert(result.args.input is 'src', 'Command-specific options should parse after command dispatch')
   assert(result.args.release is true, 'Command-specific flags should parse after command dispatch')
end

@Test function CommandSpecificOptionsAreScoped()
   parser = options({
      commands = array<table> {
         {
            name = 'build',
            args = array<table> {
               { name = 'input' }
            }
         },
         {
            name = 'test',
            args = array<table> {
               { name = 'filter' }
            }
         }
      }
   })

   result = parser.process(array<string> { 'test', 'filter=svg' })
   assert(result.command is 'test', 'Selected command should be returned')
   assert(result.args.filter is 'svg', 'Selected command arguments should parse')
   assert(result.args.input is nil, 'Arguments from other commands should not leak into the selected command')

   expect_error(parser, array<string> { 'build', 'filter=svg' }, ERR_ParameterUnknown, "Unknown parameter 'filter'.")
   expect_error(parser, array<string> { 'input=src', 'build' }, ERR_ParameterUnknown, "Unknown parameter 'input'.")
end

@Test function MissingAndUnknownCommandsFail()
   parser = options({
      commands = array<table> {
         { name = 'build' }
      }
   })

   expect_error(parser, array<string> { }, ERR_ParameterRequired, 'Command is required.')
   expect_error(parser, array<string> { 'unknown' }, ERR_ParameterUnknown, "Unknown parameter 'unknown'.")
   expect_error(parser, { command = 'unknown' }, ERR_ParameterUnknown, "Unknown command 'unknown'.")
end

@Test function CommandTableInput()
   parser = options({
      args = array<table> {
         { name = 'verbose', kind = 'flag', type = 'bool' }
      },
      commands = array<table> {
         {
            name = 'build',
            args = array<table> {
               { name = 'count', type = 'int' }
            }
         }
      }
   })

   result = parser.process({
      command = 'build',
      globals = { verbose = true },
      args = { count = '4' }
   })

   assert(result.command is 'build', 'Table input should select a command')
   assert(result.globals.verbose is true, 'Table input should parse global command values')
   assert(result.args.count is 4, 'Table input should parse command arguments')
end

@Test function CommandEnvironmentValues()
   set_test_env('KOTUKU_OPTIONS_COMMAND_VERBOSE', 'yes')
