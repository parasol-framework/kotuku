@Test function InvalidHttpVersion()
   content = ''

   http = obj.new('http', {
      src = 'http://127.0.0.1:' .. SERVER_PORT .. '/version/test',
      method = 'GET',
      flags = HTF_NO_HEAD,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "HTTP version test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, 'HTTP version processing failed: ' .. mSys.GetErrorMsg(err))

   -- Should get normal response since HTTP/1.1 is supported
   assert(http.status is 200, 'HTTP version test unexpected status: ' .. http.status)

   print('HTTP version test passed')
end

----------------------------------------------------------------------------------------------------------------------

@Test function EmptyRequest()
   content = ''

   http = obj.new('http', {
      src       = f'http://127.0.0.1:{SERVER_PORT}/empty/request',
      method    = 'POST',
      flags     = HTF_NO_HEAD,
      contentLength = -1,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      outgoing = function(HTTP)
         check ERR_Terminate
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "Empty request test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, 'Empty request processing failed: ' .. mSys.GetErrorMsg(err))
   assert(http.status is 200, 'Empty request unexpected status: ' .. http.status)

   response = json.decode(content)
   assert(response.bodyLength is 0, 'Empty request should have no body')

   print('Empty request test passed')
end
