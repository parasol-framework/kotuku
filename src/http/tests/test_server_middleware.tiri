@Test function RouteNotFound()
   content = ''

   http = obj.new('http', {
      src = 'http://127.0.0.1:' .. SERVER_PORT .. '/nonexistent/route',
      method = 'GET',
      flags = HTF_NO_HEAD,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "404 test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, '404 processing failed: ' .. mSys.GetErrorMsg(err))
   assert(http.error is ERR_Okay, '404 HTTP error: ' .. mSys.GetErrorMsg(http.error))
   assert(http.status is 404, 'Expected 404 Not Found, got: ' .. http.status)

   print('Route not found test passed - 404 received')
end

