@Test function MethodNotAllowed()
   content = ''

   http = obj.new('http', {
      src = 'http://127.0.0.1:' .. SERVER_PORT .. '/api/get-only-route',
      method = 'POST', -- Route only supports GET
      flags = HTF_NO_HEAD,
      inputFile = 'string:test',
      size = 4,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "405 test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, '405 processing failed: ' .. mSys.GetErrorMsg(err))
   assert(http.error is ERR_Okay, '405 HTTP error: ' .. mSys.GetErrorMsg(http.error))
   assert(http.status is 405, 'Expected 405 Method Not Allowed, got: ' .. http.status)

   print('Method not allowed test passed - 405 received')
end

