@Test function WildcardRoute()
   content = ''

   http = obj.new('http', {
      src = 'http://127.0.0.1:' .. SERVER_PORT .. '/api/wildcard/anything/here',
      method = 'GET',
      flags = HTF_NO_HEAD,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "Wildcard test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, 'Wildcard processing failed: ' .. mSys.GetErrorMsg(err))
   assert(http.error is ERR_Okay, 'Wildcard HTTP error: ' .. mSys.GetErrorMsg(http.error))
   assert(http.status is 200, 'Wildcard unexpected status: ' .. http.status)

   response = json.decode(content)
   assert(response.wildcardMatch, 'Wildcard route should match')
   assert(response.capturedPath, 'Wildcard should capture remaining path')

   print('Wildcard route test passed')
end

----------------------------------------------------------------------------------------------------------------------

@Test function CORSMiddleware()
   content = ''

   http = obj.new('http', {
      src = 'http://127.0.0.1:' .. SERVER_PORT .. '/api/cors-test',
      method = 'OPTIONS', -- CORS preflight
      flags = HTF_NO_HEAD,
      incoming = function(HTTP, Buffer)
         content ..= Buffer:getString()
      end,
      stateChanged = function(HTTP, State)
         if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
            HTTP.acSignal()
         end
      end
   })

   check http.acSetKey('Origin', 'https://example.com')
   check http.acSetKey('Access-Control-Request-Method', 'POST')
   check http.acSetKey('Access-Control-Request-Headers', 'Content-Type')
   proc = processing.new({ timeout = 5.0, signals = array<object> { http } })
   assert(http.acActivate() is ERR_Okay, "CORS test failed to activate")

   err = proc.sleep()
   assert(err is ERR_Okay, 'CORS processing failed: ' .. mSys.GetErrorMsg(err))
   assert(http.error is ERR_Okay, 'CORS HTTP error: ' .. mSys.GetErrorMsg(http.error))
   assert(http.status is 200, 'CORS unexpected status: ' .. http.status)

   -- CORS preflight should return empty body with CORS headers
   assert(content is '', 'CORS preflight should return empty body')

   print('CORS middleware test passed')
end
