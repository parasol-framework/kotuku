--[[ Concurrent Requests Testing --]]

   import 'net/httpserver'
   import 'json'
   include 'http'

SERVER_PORT <const> = 18948

@BeforeAll function init(State)
   global glPath = State.folder

   global glServer = hslib.start({
      port    = SERVER_PORT,
      folder  = glPath,
      verbose = true,
      routes  = {
         { pattern = '/api/parallel/:id',
            method = 'GET',
            handler = function(req, res)
               -- Small delay to simulate processing
               print('/api/parallel/:id');
               processing.sleep(math.random(50, 200)/1000)
               res.json({
                  message = 'Parallel request processed',
                  requestId = req.params.id,
                  timestamp = mSys.PreciseTime()
               })
            end
         },
         { pattern = '/api/concurrent-post',
            method = 'POST',
            handler = function(req, res)
               local data = req.parsedBody or {}
               processing.sleep(math.random(10, 100)/1000) -- Simulate processing time
               res.json({
                  message = 'Concurrent POST processed',
                  receivedId = data.id,
                  receivedData = data.data,
                  timestamp = mSys.PreciseTime()
               })
            end
         },
         { pattern = '/api/load-test/:id',
            method = 'GET',
            handler = function(req, res)
               res.json({
                  message = 'Load test response',
                  requestId = req.params.id,
                  timestamp = mSys.PreciseTime()
               })
            end
         },
         { pattern = '/api/slow-response',
            method = 'GET',
            handler = function(req, res)
               -- Slow response for timeout testing
               processing.sleep(1) -- Delay
               res.json({
                  message = 'Slow response delivered',
                  timestamp = mSys.PreciseTime()
               })
            end
         }
      }
   })
end

@AfterAll function cleanup()
   glServer.stop()
end

----------------------------------------------------------------------------------------------------------------------

@Test function ParallelRequests()
   results = {}
   completed = 0
   TOTAL_REQ <const> = 10
   wait_http = nil

   for i = 0, TOTAL_REQ-1 do
      results[i] = {}
      results[i].http = obj.new('http', {
         src    = f'http://127.0.0.1:{SERVER_PORT}/api/parallel/{i}',
         method = 'GET',
         flags  = HTF_NO_HEAD,
         incoming = function(HTTP, Buffer)
            if not results[i].data then results[i].data = '' end
            results[i].data ..= Buffer:getString()
            print(f'Received: {#results[i].data} bytes')
         end,
         stateChanged = function(HTTP, State)
            if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
               completed++
               print(f'Completed {completed} of {TOTAL_REQ}')
               if completed >= TOTAL_REQ then
                  wait_http.acSignal()
               end
            end
         end
      })
      if not wait_http then wait_http = results[i].http end
   end

   proc = processing.new({ timeout = 5.0, signals = array<object> { wait_http } })

   for i = 0, TOTAL_REQ-1 do
      assert(results[i].http.acActivate() is ERR_Okay, "Parallel request " .. i .. " failed to activate")
   end

   print('Sleeping...')
   check proc.sleep()

   assert(completed is TOTAL_REQ, 'Not all parallel requests completed: ' .. completed .. '/' .. TOTAL_REQ)

   -- Verify all responses
   for i = 0, TOTAL_REQ-1 do
      assert(results[i].data, 'No response for request ' .. i)
      response = json.decode(results[i].data)
      assert(response.requestId is tostring(i), 'Request ID mismatch for request ' .. i)
   end

   print('Parallel requests test passed: ' .. TOTAL_REQ .. ' concurrent requests')
end

----------------------------------------------------------------------------------------------------------------------

@Test function ConcurrentPOST()
   results = {}
   completed = 0
   total_posts = 3
   wait_http = nil

   for i = 0, total_posts-1 do
      test_data = f'{{"id":{i},"data":"test_data_{i}"}}'
      results[i] = {}
      results[i].http = obj.new('http', {
         src         = 'http://127.0.0.1:' .. SERVER_PORT .. '/api/concurrent-post',
         method      = 'POST',
         contentType = 'application/json',
         flags       = HTF_NO_HEAD,
         inputFile   = 'string:' .. test_data,
         size        = test_data:len(),
         incoming = function(HTTP, Buffer)
            if not results[i].data then results[i].data = '' end
            results[i].data ..= Buffer:getString()
         end,
         stateChanged = function(HTTP, State)
            if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
               completed++
               if completed >= total_posts then
                  wait_http.acSignal()
               end
            end
         end
      })
      if not wait_http then wait_http = results[i].http end
   end

   proc = processing.new({ timeout = 10.0, signals = array<object> { wait_http } })

   for i = 0, total_posts-1 do
      assert(results[i].http.acActivate() is ERR_Okay, "Concurrent POST " .. i .. " failed to activate")
   end

   check proc.sleep()

   assert(completed is total_posts, 'Not all concurrent POSTs completed: ' .. completed .. '/' .. total_posts)

   -- Verify all POST responses
   for i = 0, total_posts-1 do
      response = json.decode(results[i].data)
      assert(response.receivedId is i, 'POST ID mismatch for request ' .. i)
   end

   print('Concurrent POST test passed: ' .. total_posts .. ' concurrent POSTs')
end

----------------------------------------------------------------------------------------------------------------------

@Test function HighLoadRequests()
   results = {}
   completed = 0
   TOTAL_REQ <const> = 80
   wait_http = nil

   print('Starting high load test with ' .. TOTAL_REQ .. ' requests...')

   for i = 0, TOTAL_REQ-1 do
      results[i] = {}
      results[i].http = obj.new('http', {
         src            = 'http://127.0.0.1:' .. SERVER_PORT .. '/api/load-test/' .. i,
         method         = 'GET',
         flags          = HTF_NO_HEAD,
         connectTimeout = 5,
         incoming = function(HTTP, Buffer)
            if not results[i].data then results[i].data = '' end
            if Buffer then results[i].data ..= Buffer:getString() end
         end,
         stateChanged = function(HTTP, State)
            if (State is HGS_COMPLETED) or (State is HGS_TERMINATED) then
               completed++
               if completed >= TOTAL_REQ then
                  wait_http.acSignal()
               end
            end
         end
      })
      if not wait_http then wait_http = results[i].http end
   end

   proc = processing.new({ timeout = 5.0, signals = array<object> { wait_http } })

   for i = 0, TOTAL_REQ-1 do
      assert(results[i].http.acActivate() is ERR_Okay, "High load request " .. i .. " failed to activate")

      -- Small delay to stagger requests slightly
      if (i % 3 is 0) then mSys.WaitTime(0.1) end
   end

   check proc.sleep()

   -- Allow for some failures under high load
   success_rate = completed / TOTAL_REQ
   assert(success_rate >= 0.8, 'Success rate too low under high load: ' .. (success_rate * 100) .. '%')

   print('High load test passed: ' .. completed .. '/' .. TOTAL_REQ .. ' requests succeeded')
end
