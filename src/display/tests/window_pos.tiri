#!/usr/bin/env origo

   import 'gui/window'

   mGfx ?= mod.load('display')

   win = gui.window({ title='Keyboard Example', insideWidth=400, insideHeight=200,
      maxWidth=600, maxHeight=300, minWidth=400, minHeight=200 })

   viewport = win:clientViewport({ aspectRatio = ARF_MEET })

   tx_display = viewport.new('VectorText', {
      string='', face='Inconsolata', fontStyle='bold', fontSize=18, y=20, x=10, fill='rgb(0,0,0)'
   })

   surface = win.surface
   display = win.surface.display

function get_display_info()
   str = ''

   err, info = mGfx.GetDisplayInfo(display)
   if err is ERR_Okay then
      str ..= f'Refresh Rate Range: {info.minRefresh} - {info.maxRefresh}\n'
      str ..= f'Refresh Rate: {info.refreshRate}\n'
      str ..= f'Display ID: #{info.display}\n'
      str ..= f'Surface: {surface.x}x{surface.y} {surface.width}x{surface.height}\n'
      str ..= f'Display Size: {info.width}x{info.height}\n'
      str ..= f'Host X/Y: {info.hostedX}x{info.hostedY}\n'
      str ..= f'Monitor Size: {info.monitorX}x{info.monitorY} {info.monitorWidth}x{info.monitorHeight}\n'
      str ..= f'Virtual Size: {info.virtualX}x{info.virtualY} {info.virtualWidth}x{info.virtualHeight}\n'
      str ..= f'Physical Size: {info.physicalWidth}mm x {info.physicalHeight} mm'
   end

   tx_display.string = str
end

   win.surface.subscribe('redimension', function(Surface:obj, Args:table)
      get_display_info()
      win.surface.mtScheduleRedraw()
   end)

   win:show()
   get_display_info()
   processing.sleep()
