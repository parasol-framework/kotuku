-- ResolveVariable integration tests

   include 'xml'

   mXQ ?= mod.load('xquery')

@Test function ResolveVariableNativeCallbackTests()
   passed, total = mod.test(mXQ, 'resolve_variable')
   assert(total > 0, 'ResolveVariable native callback tests should execute at least one assertion')
   assert(passed is total, 'ResolveVariable native callback tests failed: passed ' .. passed .. ' of ' .. total)
end
