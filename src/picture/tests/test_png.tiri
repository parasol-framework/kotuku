   'data/xs4n0g01.png',
   'data/xs7n0g01.png'
}

local glDataFolder

@BeforeAll function setup(State)
   glDataFolder = State.folder
   err = mSys.CreateFolder(glResultFolder, 0)
   if (err != ERR_Okay) and (err != ERR_FileExists) then
      error('CreateFolder() failed for ' .. glResultFolder .. ': ' .. mSys.GetErrorMsg(err))
   end
end

function formatHash(Hash:num)
   return string.format('0x%.8x', Hash)
end

function saveBitmap(Picture:obj, Name:str)
   try
      file = obj.new('file', { flags=FL_NEW|FL_WRITE, path=glResultFolder .. Name })
      Picture.acSaveImage(file)
   except ex
      logOutput('Unable to save decoded PNG result for "' .. Name .. '": ' .. ex.message)
   end
end

----------------------------------------------------------------------------------------------------------------------

@Test global function ValidPNGHashes()
   missing = array<string> { }
   mismatches = array<string> { }

   for record in values(glValidPNG) do
      local hash, bmp, pic

      try
         pic = obj.new('picture', { path=glDataFolder .. record.src })
         bmp = pic.bitmap
         hash = mSys.GenCRC32(0, bmp.data, bmp.size)
      except ex
         mismatches:push(record.src .. ': load failed: ' .. ex.message)
         continue
      success
         if not record.crc?? then
            saveBitmap(bmp, record.src)
            missing:push("   { src='" .. record.src .. "', crc=" .. formatHash(hash) .. ' },')
         elseif record.crc != hash then
            saveBitmap(bmp, record.src)
            mismatches:push(record.src .. ': computed ' .. formatHash(hash) .. ', expected ' .. formatHash(record.crc))
         end

         if record.mask_crc then
            if not pic.mask then
               mismatches:push(record.src .. ': expected alpha mask but none was loaded')
            else
               local mask_hash = mSys.GenCRC32(0, pic.mask.data, pic.mask.size)

               if record.mask_crc != mask_hash then
                  mismatches:push(record.src .. ': mask computed ' .. formatHash(mask_hash) ..
                     ', expected ' .. formatHash(record.mask_crc))
               end
            end
         end
      end
   end

   if (#missing > 0) or (#mismatches > 0) then
      message = ''
      if #missing > 0 then
         message ..= 'Missing Picture PNG CRC values:\n' .. missing:concat('\n')
      end
      if #mismatches > 0 then
         if #message > 0 then message ..= '\n\n' end
         message ..= 'Picture PNG CRC mismatches or load failures:\n' .. mismatches:concat('\n')
      end
      error(message)
   end
end

----------------------------------------------------------------------------------------------------------------------

@Test global function InvalidPNGsFailToLoad()
   failures = array<string> { }

   for record in values(glInvalidPNG) do
      try
         obj.new('picture', { path=glDataFolder .. record })
      success
         failures:push(record .. ': loaded successfully but should be rejected')
      end
   end

   if #failures > 0 then
      error('Invalid PNG files loaded successfully:\n' .. failures:concat('\n'))
   end
end
