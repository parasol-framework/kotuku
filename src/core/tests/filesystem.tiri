@Test function ResolvePathNoFileCheck()
   missing_path = glTempRoot .. 'resolve_path.tmp'
   resetPath(missing_path)

   err = mSys.ResolvePath(missing_path)
   assert(err is ERR_FileNotFound, 'ResolvePath() without RSF_NO_FILE_CHECK should fail for a missing file, got: ' .. mSys.GetErrorMsg(err))

   err, resolved_path = mSys.ResolvePath(missing_path, RSF_NO_FILE_CHECK)
   assert(err is ERR_Okay, 'ResolvePath() with RSF_NO_FILE_CHECK failed: ' .. mSys.GetErrorMsg(err))
   assert(type(resolved_path) is 'string', 'ResolvePath() should return a string result.')
   assert(#resolved_path > 0, 'ResolvePath() returned an empty path string.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function ResolvePathApproximateAndCanonical()
   test_root = glTempRoot .. 'resolve_path/'
   nested_path = test_root .. 'nested/'
   target_path = test_root .. 'resolve_approx.txt'

   resetPath(test_root)
   ensureFolder(nested_path)
   writeFile(target_path, 'Resolve path content')

   err, exact_path = mSys.ResolvePath(target_path)
   assert(err is ERR_Okay, 'ResolvePath() failed for the exact path: ' .. mSys.GetErrorMsg(err))

   err, approx_path = mSys.ResolvePath('~' .. test_root .. 'resolve_approx')
   assert(err is ERR_Okay, 'ResolvePath() failed for the approximated path: ' .. mSys.GetErrorMsg(err))
   assert(approx_path is exact_path, 'ResolvePath() should resolve approximated paths to the same target.')

   err, flag_approx_path = mSys.ResolvePath(test_root .. 'resolve_approx', RSF_APPROXIMATE)
   assert(err is ERR_Okay, 'ResolvePath() with RSF_APPROXIMATE failed: ' .. mSys.GetErrorMsg(err))
   assert(flag_approx_path is exact_path, 'RSF_APPROXIMATE should resolve to the same canonical path as the exact reference.')

   err, normalised_path = mSys.ResolvePath(test_root .. 'nested/../resolve_approx.txt')
   assert(err is ERR_Okay, 'ResolvePath() failed for a path requiring canonicalisation: ' .. mSys.GetErrorMsg(err))
   assert(normalised_path is exact_path, 'ResolvePath() should canonicalise "." and ".." segments.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function ResolvePathSpecialCases()
   err = mSys.ResolvePath('codex_missing_volume:missing.file')
   assert(err is ERR_Search, 'ResolvePath() should return ERR_Search for an unknown volume, got: ' .. mSys.GetErrorMsg(err))

   err, string_path = mSys.ResolvePath('string:hello world')
   assert(err is ERR_Okay, 'ResolvePath() failed for a string: path: ' .. mSys.GetErrorMsg(err))
   assert(string_path is 'string:hello world', 'ResolvePath() should return string: paths unchanged.')

   err = mSys.ResolvePath(':', RSF_CHECK_VIRTUAL)
   assert(err is ERR_VirtualVolume, 'ResolvePath() with RSF_CHECK_VIRTUAL should report the virtual root, got: ' .. mSys.GetErrorMsg(err))

   err, root_path = mSys.ResolvePath(':')
   assert(err is ERR_Okay, 'ResolvePath() should accept the virtual root path: ' .. mSys.GetErrorMsg(err))
   assert(type(root_path) is 'string', 'ResolvePath() should return a string for the virtual root path.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function CompareFilePaths()
   compare_path = glTempRoot .. 'compare_file.tmp'

   resetPath(compare_path)

   writeFile(compare_path, 'Compare me')

   err, resolved_path = mSys.ResolvePath(compare_path)
   assert(err is ERR_Okay, 'ResolvePath() failed for CompareFilePaths() test: ' .. mSys.GetErrorMsg(err))

   err = mSys.CompareFilePaths(compare_path, resolved_path)
   assert(err is ERR_Okay, 'CompareFilePaths() should match equivalent paths, got: ' .. mSys.GetErrorMsg(err))
end

----------------------------------------------------------------------------------------------------------------------

@Test function CreateFolderAndDeleteTree()
   root_path = glTempRoot .. 'create_folder/'
   folder_path = root_path .. 'alpha/beta/'
   child_path = folder_path .. 'child.txt'

   resetPath(root_path)

   err = mSys.CreateFolder(folder_path, 0)
   assert(err is ERR_Okay, 'CreateFolder() failed: ' .. mSys.GetErrorMsg(err))

   err = mSys.CreateFolder(folder_path, 0)
   assert(err is ERR_FileExists, 'CreateFolder() should report ERR_FileExists for an existing folder, got: ' .. mSys.GetErrorMsg(err))

   err, type = mSys.AnalysePath(folder_path)
   assert(err is ERR_Okay, 'AnalysePath() failed for created folder: ' .. mSys.GetErrorMsg(err))
   assert(type is LOC_FOLDER, 'AnalysePath() returned type ' .. type .. ' and not LOC_FOLDER')

   writeFile(child_path, 'Nested content')

   err = mSys.DeleteFile(root_path)
   assert(err is ERR_Okay, 'DeleteFile() failed to remove a folder tree: ' .. mSys.GetErrorMsg(err))

   err = mSys.AnalysePath(root_path)
   assert(err != ERR_Okay, 'Folder tree should no longer exist after DeleteFile().')
end

----------------------------------------------------------------------------------------------------------------------

@Test function CopyFile()
   src_path = glTempRoot .. 'copy_source.tmp'
   dest_path = glTempRoot .. 'copy_dest.tmp'
   callback_hits = 0

   resetPath(src_path)
   resetPath(dest_path)

   writeFile(src_path, 'Copied content')

   err = mSys.CopyFile(src_path, dest_path, function(Size, Position, Path, Dest, User, FeedbackID)
      callback_hits++
      return FFR_OKAY
   end)

   assert(err is ERR_Okay, 'CopyFile() failed: ' .. mSys.GetErrorMsg(err))
   assert(callback_hits > 0, 'CopyFile() callback was not invoked.')
   assert(readFile(dest_path) is 'Copied content', 'CopyFile() did not preserve the source file content.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function MoveFile()
   src_path = glTempRoot .. 'move_source.tmp'
   dest_path = glTempRoot .. 'move_dest.tmp'

   resetPath(src_path)
   resetPath(dest_path)

   writeFile(src_path, 'Moved content')

   err = mSys.MoveFile(src_path, dest_path)
   assert(err is ERR_Okay, 'MoveFile() failed: ' .. mSys.GetErrorMsg(err))

   err = mSys.AnalysePath(src_path)
   assert(err != ERR_Okay, 'MoveFile() should remove the source file.')

   assert(readFile(dest_path) is 'Moved content', 'MoveFile() did not preserve the file content.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function ReadFileToBuffer()
   read_path = glTempRoot .. 'buffer_read.txt'
   expected = 'Buffer content'

   resetPath(read_path)
   writeFile(read_path, expected)

   buffer = array<byte, #expected>
   err = mSys.ReadFileToBuffer(read_path, buffer)
   assert(err is ERR_Okay, 'ReadFileToBuffer() failed: ' .. mSys.GetErrorMsg(err))
   assert(buffer:getString() is expected, 'ReadFileToBuffer() did not return the expected text.')

   approx_buffer = array<byte, #expected>
   err = mSys.ReadFileToBuffer('~' .. glTempRoot .. 'buffer_read', approx_buffer)
   assert(err is ERR_Okay, 'ReadFileToBuffer() failed for an approximated path: ' .. mSys.GetErrorMsg(err))
   assert(approx_buffer:getString() is expected, 'ReadFileToBuffer() did not resolve the approximated path correctly.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function InfoTags()
   info = struct.new('FileInfo')

   err = mSys.AddInfoTag(info, 'Label', 'Filesystem test')
   assert(err is ERR_Okay, 'AddInfoTag() failed: ' .. mSys.GetErrorMsg(err))

   err, value = mSys.ReadInfoTag(info, 'Label')
   assert(err is ERR_Okay, 'ReadInfoTag() failed to retrieve an existing tag: ' .. mSys.GetErrorMsg(err))
   assert(value is 'Filesystem test', 'ReadInfoTag() returned an unexpected value: ' .. tostring(value))

   err = mSys.AddInfoTag(info, 'Label', nil)
   assert(err is ERR_Okay, 'AddInfoTag() failed to remove a tag: ' .. mSys.GetErrorMsg(err))

   err, value = mSys.ReadInfoTag(info, 'Label')
   assert(err is ERR_Search, 'ReadInfoTag() should report ERR_Search after a tag is removed, got: ' .. mSys.GetErrorMsg(err))
   assert(value is nil, 'ReadInfoTag() should return nil for a removed tag.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function WatchFolder()
   folder = obj.new('file', { path='temp:' })

   events = array<table> { }
   err = folder.mtWatch(function(File, Path, Flags)
      events:push({ path=tostring(Path), flags=Flags })
      return ERR_Okay
   end, MFF_CREATE|MFF_DELETE|MFF_CLOSED|MFF_MOVED|MFF_ATTRIB)

   if err is ERR_NoSupport then
      return 'Host platform does not support file system watching.'
   end
   assert(err is ERR_Okay, 'Watch() failed: ' .. mSys.GetErrorMsg(err))

   watchFile = 'temp:watch_test.tmp'

   out = obj.new('file', { src=watchFile, flags=FL_NEW|FL_WRITE })
   out.acWrite('XYZ', 3)
   out.free()

   -- Pump the message queue so inotify / ReadDirectoryChangesW events are delivered.
   for i=0,20 do
      processing.sleep(0.05)
      if #events > 0 then break end
   end

   mSys.DeleteFile(watchFile)

   processing.sleep(0.5)

   -- Disable the watch prior to assertions so state is clean even on failure.
   folder.mtWatch()

   assert(#events > 0, 'No file system events were delivered to the watch callback.')

   local created = false
   for e in values(events) do
      logOutput(f'Event path="{e.path}", flags=${string.format("%.8x", e.flags)}')
      if (e.flags & MFF_CREATE) != 0 then created = true end
   end

   assert(created, 'Expected at least one MFF_CREATE event for ' .. watchFile)
   logOutput(f'Received {#events} file system event(s).')
end

----------------------------------------------------------------------------------------------------------------------

@Test function WatchDisable()
   folder = obj.new('file', { path='temp:' })

   err = folder.mtWatch(function(File, Path, Flags) return ERR_Okay end, MFF_CREATE|MFF_DELETE)
   if err is ERR_NoSupport then
      return 'Host platform does not support file system watching.'
   end
   assert(err is ERR_Okay, 'Initial Watch() failed: ' .. mSys.GetErrorMsg(err))

   -- Disabling with no arguments must succeed cleanly.
   err = folder.mtWatch()
   assert(err is ERR_Okay, 'Disabling Watch() with no arguments failed: ' .. mSys.GetErrorMsg(err))

   -- A second disable is a no-op and must still succeed.
   err = folder.mtWatch()
   assert(err is ERR_Okay, 'Second Watch() disable call failed: ' .. mSys.GetErrorMsg(err))
end

----------------------------------------------------------------------------------------------------------------------

@Test function FileInfoStructCppString()
   info = struct.new('FileInfo')
   assert(type(info.name) is 'string', 'FileInfo.Name should default to a valid string')

   err = mSys.GetFileInfo('scripts:gui.tiri', info)
   assert(err is ERR_Okay, 'GetFileInfo() failed on first call: ' .. mSys.GetErrorMsg(err))
   assert(type(info.name) is 'string', 'FileInfo.Name should remain a string after GetFileInfo()')
   assert(#info.name > 0, 'GetFileInfo() returned an empty file name')

   err = mSys.GetFileInfo('scripts:gui/window.tiri', info)
   assert(err is ERR_Okay, 'GetFileInfo() failed on second call: ' .. mSys.GetErrorMsg(err))
   assert(type(info.name) is 'string', 'FileInfo.Name should still be a string after reuse')
   assert(#info.name > 0, 'GetFileInfo() returned an empty file name on reuse')
end
