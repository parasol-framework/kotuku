-- $TIRI
-- Flute tests for the Document class.
--
-- This technique uses pre-computed checksums from the Document's bitmap output, captured from a 'good' state.  If a
-- checksum doesn't match, the test will fail and the resulting image will be saved to "temp:doc_test_results/".
-- You can view the saved image files to confirm the accuracy of the results.  If the test has passed then update the
-- old checksum with the new one provided in this program's output.

@BeforeAll function init(State)
   global glDocFolder = State.folder
end

function saveBitmap(Bitmap, Name)
   filename = Name .. '.png'

   pic = obj.new('picture', { width = Bitmap.width, height = Bitmap.height, bitsPerPixel = Bitmap.bitsPerPixel, flags=PCF_NEW })
   Bitmap.acCopyData(pic.bitmap)
   fl = obj.new('file', { flags=FL_NEW|FL_WRITE, path='temp:doc_test_results/' .. filename })
   pic.acSaveImage(fl)
end

-----------------------------------------------------------------------------------------------------------------------

function renderDocToBitmap(Path:str, Width:num)
   scene = obj.new('VectorScene', { pageWidth=Width ?? 1024, pageHeight=768 })
   vp = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   vp.new('VectorRectangle', { x=0, y=0, width='100%', height='100%', fill='rgb(255,255,255)' })

   doc = vp.new('document', { viewport=vp, path=Path })
   scene.pageHeight = doc.pageHeight

   bmp = obj.new('bitmap', { width=scene.pageWidth, height=doc.pageHeight, bitsPerPixel=32 })
   bmp.acClear()

   scene.bitmap = bmp
   scene.acDraw()
   return bmp
end

function crcTest(Name:str, Path:str, ExpectedCRC:any)
   if type(ExpectedCRC) is 'table' then
      for res,crc in pairs(ExpectedCRC) do
         print('Testing at ' .. res .. 'px width')
         bmp = renderDocToBitmap(glDocFolder .. Path, res)

         bmp_crc = mSys.GenCRC32(0, bmp.data, bmp.size)
         if (crc is 0) then
            saveBitmap(bmp, Name .. '_' .. res)
            error('File "' .. Path .. '" @ page width ' .. res .. ' is yet to be assigned a checksum, current CRC is ' .. string.format('0x%.8x', bmp_crc))
         elseif (crc != bmp_crc) then
            saveBitmap(bmp, Name .. '_' .. res)
            error('The CRC for "' .. Path .. '" @ page width ' .. res .. ' is ' .. string.format('0x%.8x', bmp_crc) .. ', expected ' .. string.format('0x%.8x', crc))
         end
      end
      return
   end

   bmp = renderDocToBitmap(glDocFolder .. Path, 1024)

   crc = mSys.GenCRC32(0, bmp.data, bmp.size)
   if (ExpectedCRC is 0) then
      saveBitmap(bmp, Name)
      error('The ' .. Name .. ' test is yet to be assigned a checksum, current CRC is ' .. string.format('0x%.8x', crc))
   elseif (ExpectedCRC != crc) then
      saveBitmap(bmp, Name)
      error('The CRC for ' .. Name .. ' is ' .. string.format('0x%.8x', crc) .. ', expected ' .. string.format('0x%.8x', ExpectedCRC))
   else
      --saveBitmap(bmp, Name)
   end
end

-----------------------------------------------------------------------------------------------------------------------

@Test(priority=1) function Alignment()   crcTest('Alignment', 'alignment.rpl', { [1024] = 0x85bb7d83, [600] = 0x13d66263, [400] = 0xe26c5e2e }) end
@Test(priority=4) function Dialog()      crcTest('Dialog', 'dialog.rpl', 0x0a3b263b) end
@Test(priority=4) function Fonts()       crcTest('Fonts', 'fonts.rpl', 0x829d5302) end
@Test(priority=4) function Images()      crcTest('Images', 'images.rpl', 0xeed1ff8e) end
@Test(priority=4) function Layout()      crcTest('Layout', 'layout.rpl', 0x3042638c) end
@Test(priority=4) function Links1()      crcTest('Links1', 'links.rpl', 0x8de8dbec) end
@Test(priority=4) function Links2()      crcTest('Links2', 'links.rpl?font=Noto Sans&font-size=16', 0x7a14df25) end
@Test(priority=4) function Lists()       crcTest('Lists', 'lists.rpl', 0xef24b73f) end
@Test(priority=4) function Logic()       crcTest('Logic', 'logic.rpl', 0xfacb7a70) end
@Test(priority=4) function Paragraphs()  crcTest('Paragraphs', 'paragraphs.rpl', 0x3a42c6a2) end
@Test(priority=2) function Tables()      crcTest('Tables', 'tables.rpl', 0x5af62a40) end
--@Test(priority=3) function Widgets()     crcTest('Widgets', 'widgets.rpl', 0xbf1021d5) end
