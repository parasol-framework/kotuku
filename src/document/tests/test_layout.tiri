-- $TIRI
-- Flute tests for the Document class.
--
-- This technique uses pre-computed checksums from the Document's bitmap output, captured from a 'good' state.  If a
-- checksum doesn't match, the test will fail and the resulting image will be saved to "temp:doc_test_results/".
-- You can view the saved image files to confirm the accuracy of the results.  If the test has passed then update the
-- old checksum with the new one provided in this program's output.

@BeforeAll function init(State)
   global glDocFolder = State.folder
end

function saveBitmap(Bitmap, Name)
   filename = Name .. '.png'

   pic = obj.new('picture', { width = Bitmap.width, height = Bitmap.height, bitsPerPixel = Bitmap.bitsPerPixel, flags=PCF_NEW })
   Bitmap.acCopyData(pic.bitmap)
   fl = obj.new('file', { flags=FL_NEW|FL_WRITE, path=f'temp:doc_test_results/{filename}' })
   pic.acSaveImage(fl)
end

-----------------------------------------------------------------------------------------------------------------------

function renderDocToBitmap(Path:str, Width:num)
   scene = obj.new('VectorScene', { pageWidth=Width ?? 1024, pageHeight=768 })
   vp = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   vp.new('VectorRectangle', { x=0, y=0, width='100%', height='100%', fill='rgb(255 255 255)' })

   doc = vp.new('document', { viewport=vp, path=Path })
   scene.pageHeight = doc.pageHeight

   bmp = obj.new('bitmap', { width=scene.pageWidth, height=doc.pageHeight, bitsPerPixel=32 })
   bmp.acClear()

   scene.bitmap = bmp
   scene.acDraw()
   return bmp
end

function crcTest(Name:str, Path:str, ExpectedCRC:any, TimeLimit:num)
   if type(ExpectedCRC) is 'table' then
      for res, crc in pairs(ExpectedCRC) do
         print(f'Testing at {res}px width')
         startTime = mSys.PreciseTime()
         bmp = renderDocToBitmap(glDocFolder .. Path, res)
         timeTaken = (mSys.PreciseTime() - startTime) / 1000000

         bmp_crc = mSys.GenCRC32(0, bmp.data, bmp.size)
         if crc is 0 then
            saveBitmap(bmp, f'{Name}_{res}')
            error(f'File "{Path}" @ page width {res} is yet to be assigned a checksum, current CRC is {string.format("0x%.8x", bmp_crc)}')
         elseif crc != bmp_crc then
            saveBitmap(bmp, f'{Name}_{res}')
            error(f'The CRC for "{Path}" @ page width {res} is {string.format("0x%.8x", bmp_crc)}, expected {string.format("0x%.8x", crc)}')
         end

         if TimeLimit and (timeTaken > TimeLimit) and (mSys.GetSystemState().ReleaseBuild is 1) then
            error(f'File "{Path}" @ page width {res} took {timeTaken}s to render, expected {TimeLimit}s')
         end
      end
      return
   end

   startTime = mSys.PreciseTime()
   bmp = renderDocToBitmap(glDocFolder .. Path, 1024)
   timeTaken = (mSys.PreciseTime() - startTime) / 1000000

   crc = mSys.GenCRC32(0, bmp.data, bmp.size)
   if ExpectedCRC is 0 then
      saveBitmap(bmp, Name)
      error(f'The {Name} test is yet to be assigned a checksum, current CRC is {string.format("0x%.8x", crc)}')
   elseif ExpectedCRC != crc then
      saveBitmap(bmp, Name)
      error(f'The CRC for {Name} is {string.format("0x%.8x", crc)}, expected {string.format("0x%.8x", ExpectedCRC)}')
   else
      --saveBitmap(bmp, Name)
   end

   if TimeLimit and (timeTaken > TimeLimit) and (mSys.GetSystemState().ReleaseBuild is 1) then
      error(f'File "{Path}" took {timeTaken}s to render, expected {TimeLimit}s')
   end
end

-----------------------------------------------------------------------------------------------------------------------

@Test(priority=1) function Alignment()   crcTest('Alignment', 'alignment.rpl', { [1024] = 0x85bb7d83, [600] = 0x13d66263, [400] = 0xe26c5e2e }, 0.1) end
@Test(priority=4) function Dialog()      crcTest('Dialog', 'dialog.rpl', 0x3f1ed354, 0.01) end
@Test(priority=4) function Fonts()       crcTest('Fonts', 'fonts.rpl', 0x829d5302, 0.02) end
@Test(priority=4) function Images()      crcTest('Images', 'images.rpl', 0xc17f4172, 0.02) end
@Test(priority=4) function Layout()      crcTest('Layout', 'layout.rpl', 0x3042638c, 0.03) end
@Test(priority=4) function Links1()      crcTest('Links1', 'links.rpl', 0x8de8dbec, 0.02) end
@Test(priority=4) function Links2()      crcTest('Links2', 'links.rpl?font=Noto Sans&font-size=16', 0x0f242431, 0.03) end
@Test(priority=4) function Lists()       crcTest('Lists', 'lists.rpl', 0x8e0f76e2, 0.05) end
@Test(priority=4) function Logic()       crcTest('Logic', 'logic.rpl', 0x4c2e7c12, 0.03) end
@Test(priority=4) function Paragraphs()  crcTest('Paragraphs', 'paragraphs.rpl', 0x1d1921c5, 0.05) end
@Test(priority=2) function Tables()      crcTest('Tables', 'tables.rpl', 0x7ebd53e7, 0.1) end
--@Test(priority=3) function Widgets()     crcTest('Widgets', 'widgets.rpl', 0xbf1021d5, 0.01) end
