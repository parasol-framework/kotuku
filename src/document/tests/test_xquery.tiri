@Test function DataSelectRejectsNonXmlScalar()
   err = feedExpectError('<body/><page><data select="\'plain text\'"/></page>')
   assert(err != ERR_Okay, '<data select> must reject non-XML scalar results')
end

@Test function RepeatSelectRejected()
   err = feedExpectError('<body/><page><repeat select="(1, 2)"><p>BAD</p></repeat></page>')
   assert(err != ERR_Okay, 'repeat select="..." must be rejected')
end

