-- Backstage interface tests

   include 'network'

SERVER_PORT <const> = 18876

glBackstageTask = nil

@BeforeAll function startBackstage()
   current_task = mSys.CurrentTask()

   glBackstageTask = obj.new('task', {
      location = current_task.processPath .. 'origo',
      args = f'--backstage {SERVER_PORT} --statement "processing.sleep(10)" --log-warning',
      outputCallback = function(Task:obj, Buffer)
         print(Buffer:getString())
      end,
      errorCallback = function(Task:obj, Buffer)
         print(Buffer:getString())
      end
   })

   check glBackstageTask.acActivate()
   processing.halt(0.25)
end

@AfterAll function stopBackstage()
   if glBackstageTask then
      glBackstageTask.acDeactivate()
      glBackstageTask.free()
      glBackstageTask = nil
   end
end

-----------------------------------------------------------------------------------------------------------------------

function request_backstage(Request:str, ExpectedToken:str):str
   response = ''
   client = obj.new('netsocket', {
      name = 'BackstagePingClient',
      feedback = function(Socket:obj, State:num)
         if State is NTC_CONNECTED then
            err, len = Socket.acWrite(Request)
            check err
            assert(len is #Request, 'Request write length mismatch.')
         end
      end,
      incoming = function(Socket:obj)
         buffer = string.alloc(2048)
         err, read_len = Socket.acRead(buffer)
         if err is ERR_Disconnected then
            Socket.acSignal()
            return
         end
         assert(err is ERR_Okay, 'Failed to read ping response: ' .. mSys.GetErrorMsg(err))
         if read_len <= 0 then return end

         response ..= buffer:substr(0, read_len)
         if ExpectedToken?? and response:find(ExpectedToken) then
            Socket.acSignal()
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { client } })
   check client.mtConnect('127.0.0.1', SERVER_PORT)
   check proc.sleep()
   client.free()

   return response
end

function request_backstage_full(Request:str):str
   return request_backstage(Request, '')
end

function websocket_handshake(ExtraHeaders:str):str
   return 'GET /streaming HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Upgrade: websocket\r\n' ..
      'Connection: Upgrade\r\n' ..
      'Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n' ..
      'Sec-WebSocket-Version: 13\r\n' ..
      ExtraHeaders ..
      '\r\n'
end

function websocket_frame(Payload:str, Opcode:num):str
   mask = string.char(0x11, 0x22, 0x33, 0x44)
   len = #Payload
   frame = string.char(0x80 | Opcode)

   if len < 126 then
      frame ..= string.char(0x80 | len)
   elseif len < 65536 then
      frame ..= string.char(0x80 | 126)
      frame ..= string.char((len >> 8) & 0xff)
      frame ..= string.char(len & 0xff)
   else
      error('Test WebSocket frame is too large.')
   end

   frame ..= mask

   for i = 0, len - 1 do
      frame ..= string.char(Payload:byte(i) ^ mask:byte(i % 4))
   end

   return frame
end

function websocket_exchange(Frames:array, ExpectedTokens:array):str
   response = ''
   frames_sent = false

   client = obj.new('netsocket', {
      name = 'BackstageStreamingClient',
      feedback = function(Socket:obj, State:num)
         if State is NTC_CONNECTED then
            request = websocket_handshake('')
            err, len = Socket.acWrite(request)
            check err
            assert(len is #request, 'WebSocket handshake write length mismatch.')
         end
      end,
      incoming = function(Socket:obj)
         buffer = string.alloc(4096)
         err, read_len = Socket.acRead(buffer)
         if err is ERR_Disconnected then
            Socket.acSignal()
            return
         end

         assert(err is ERR_Okay, 'Failed to read WebSocket response: ' .. mSys.GetErrorMsg(err))
         if read_len <= 0 then return end

         response ..= buffer:substr(0, read_len)

         if (not frames_sent) and response:find('HTTP/1.1 101 Switching Protocols') then
            for _, frame in Frames do
               write_err, write_len = Socket.acWrite(frame)
               check write_err
               assert(write_len is #frame, 'WebSocket frame write length mismatch.')
            end
            frames_sent = true
         end

         matched = true
         for _, token in ExpectedTokens do
            if not response:find(token) then matched = false end
         end

         if matched then Socket.acSignal() end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { client } })
   check client.mtConnect('127.0.0.1', SERVER_PORT)
   check proc.sleep()
   client.free()

   return response
end

function websocket_exchange_until_disconnect(Frame:str):<str, bool>
   response = ''
   frame_sent = false
   disconnected = false

   client = obj.new('netsocket', {
      name = 'BackstageStreamingCloseClient',
      feedback = function(Socket:obj, State:num)
         if State is NTC_CONNECTED then
            request = websocket_handshake('')
            err, len = Socket.acWrite(request)
            check err
            assert(len is #request, 'WebSocket handshake write length mismatch.')
         elseif State is NTC_DISCONNECTED then
            disconnected = true
            Socket.acSignal()
         end
      end,
      incoming = function(Socket:obj)
         buffer = string.alloc(4096)
         err, read_len = Socket.acRead(buffer)
         if err is ERR_Disconnected then
            disconnected = true
            Socket.acSignal()
            return
         end

         assert(err is ERR_Okay, 'Failed to read WebSocket close response: ' .. mSys.GetErrorMsg(err))
         if read_len <= 0 then return end

         response ..= buffer:substr(0, read_len)

         if (not frame_sent) and response:find('HTTP/1.1 101 Switching Protocols') then
            write_err, write_len = Socket.acWrite(Frame)
            check write_err
            assert(write_len is #Frame, 'WebSocket frame write length mismatch.')
            frame_sent = true
         end
      end
   })

   proc = processing.new({ timeout = 5.0, signals = array<object> { client } })
   check client.mtConnect('127.0.0.1', SERVER_PORT)
   check proc.sleep()
   client.free()

   return response, disconnected
end

