function MalformedContentLengthReturnsBadRequest()
   request = 'GET /ping HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Content-Length: no\r\n' ..
      'Connection: close\r\n\r\n'

   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')
   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected malformed length to return 400, got: ' .. response)
end

@Test; @Requires(network=true)
function MissingContentLengthOnBodyRouteReturnsLengthRequired()
   request = 'POST /objects HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Content-Type: application/json\r\n' ..
      'Connection: close\r\n\r\n{}'

   response = request_backstage(request, 'HTTP/1.1 411 Length Required')
   assert(response:find('HTTP/1.1 411 Length Required'), 'Expected missing length to return 411, got: ' .. response)
end

@Test; @Requires(network=true)
function OversizedBodyReturnsPayloadTooLarge()
   request = 'POST /scripts HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Content-Length: 1048577\r\n' ..
      'Connection: close\r\n\r\n'

   response = request_backstage(request, 'HTTP/1.1 413 Payload Too Large')
   assert(response:find('HTTP/1.1 413 Payload Too Large'), 'Expected oversized body to return 413, got: ' .. response)
end

@Test; @Requires(network=true)
function JsonRouteRequiresJsonContentType()
   request = 'POST /objects HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Content-Type: text/plain\r\n' ..
      'Content-Length: 2\r\n' ..
      'Connection: close\r\n\r\n{}'

   response = request_backstage(request, 'HTTP/1.1 415 Unsupported Media Type')
   assert(response:find('HTTP/1.1 415 Unsupported Media Type'), 'Expected text body to return 415, got: ' .. response)
end

@Test; @Requires(network=true)
function UnsupportedTransferEncodingReturnsBadRequest()
   request = 'POST /scripts HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Transfer-Encoding: chunked\r\n' ..
      'Connection: close\r\n\r\n'

   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')
   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected transfer encoding 400, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingHandshakeReturnsSwitchingProtocols()
   response = websocket_exchange(array<string> { }, array<string> {
      'HTTP/1.1 101 Switching Protocols',
      'Sec-WebSocket-Accept: s3pPLMBiTxaQ9kYGzzhZRbK+xOo=',
      '"type":"event"',
      '"topic":"system"',
      '"event":"connected"',
      '"event":"heartbeat"'
   })

   assert(response:find('Upgrade: websocket'), 'Expected WebSocket upgrade response, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingAcceptsLoopbackOrigin()
   response = request_backstage(websocket_handshake('Origin: http://localhost:18876\r\n'),
      'HTTP/1.1 101 Switching Protocols')

   assert(response:find('HTTP/1.1 101 Switching Protocols'), 'Expected loopback origin to upgrade, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingRejectsLookalikeOrigin()
   request = websocket_handshake('Origin: http://localhost.attacker.example\r\n')
   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')

   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected lookalike localhost origin 400, got: ' .. response)
   assert(response:find('Origin not allowed'), 'Expected origin rejection, got: ' .. response)

   request = websocket_handshake('Origin: http://127.0.0.1.evil.example\r\n')
   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')

   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected lookalike 127.0.0.1 origin 400, got: ' .. response)
   assert(response:find('Origin not allowed'), 'Expected origin rejection, got: ' .. response)

   request = websocket_handshake('Origin: http://localhost:notaport\r\n')
   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')

   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected invalid origin port 400, got: ' .. response)
   assert(response:find('Origin not allowed'), 'Expected origin rejection, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingRejectsInvalidVersion()
   request = 'GET /streaming HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Upgrade: websocket\r\n' ..
      'Connection: Upgrade\r\n' ..
      'Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n' ..
      'Sec-WebSocket-Version: 12\r\n\r\n'

   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')

   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected invalid version to return 400, got: ' .. response)
   assert(response:find('Unsupported WebSocket version'), 'Expected version error, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingRejectsInvalidKey()
   request = 'GET /streaming HTTP/1.1\r\n' ..
      'Host: 127.0.0.1\r\n' ..
      'Upgrade: websocket\r\n' ..
      'Connection: Upgrade\r\n' ..
      'Sec-WebSocket-Key: bad-key\r\n' ..
      'Sec-WebSocket-Version: 13\r\n\r\n'

   response = request_backstage(request, 'HTTP/1.1 400 Bad Request')

   assert(response:find('HTTP/1.1 400 Bad Request'), 'Expected invalid key to return 400, got: ' .. response)
   assert(response:find('Invalid WebSocket key'), 'Expected key error, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingSubscribesToSystemTopic()
   frame = websocket_frame('{"id":"1","type":"subscribe","topics":["system"]}', 0x01)
   response = websocket_exchange(array<string> { frame }, array<string> {
      '"type":"ack"',
      '"id":"1"',
      '"command":"subscribe"',
      '"topic":"system"',
      '"event":"subscribed"'
   })

   assert(response:find('"topics":["system"]'), 'Expected system topic acknowledgement, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingSubscribesToLogStub()
   frame = websocket_frame('{"id":"2","type":"subscribe","topics":["log"]}', 0x01)
   response = websocket_exchange(array<string> { frame }, array<string> {
      '"type":"ack"',
      '"id":"2"',
      '"topic":"log"',
      '"event":"stub"'
   })

   assert(response:find('Log streaming is not connected'), 'Expected log stub event, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingUnknownTopicReturnsError()
   frame = websocket_frame('{"id":"3","type":"subscribe","topics":["unknown"]}', 0x01)
   response = websocket_exchange(array<string> { frame }, array<string> {
      '"type":"error"',
      '"id":"3"',
      '"code":"unknown_topic"'
   })

   assert(response:find('Unknown streaming topic'), 'Expected unknown topic error, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingPingReceivesPong()
   frame = websocket_frame('hello', 0x09)
   response = websocket_exchange(array<string> { frame }, array<string> {
      'HTTP/1.1 101 Switching Protocols',
      'hello'
   })

   assert(response:find('hello'), 'Expected pong payload, got: ' .. response)
end

@Test; @Requires(network=true)
function StreamingCloseDisconnectsSession()
   response, disconnected = websocket_exchange_until_disconnect(websocket_frame('', 0x08))

   assert(response:find('HTTP/1.1 101 Switching Protocols'), 'Expected WebSocket handshake, got: ' .. response)
   assert(disconnected, 'Expected WebSocket close frame to disconnect the session.')
end
