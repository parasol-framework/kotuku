})

----------------------------------------------------------------------------------------------------------------------
-- Convert a route path to a regex string

function regex_literal_char(Char:str):str
   if Char is '\\' then return '\\\\' end
   if Char is '"' then return '\\"' end

   if (Char is '.') or (Char is '^') or (Char is '$') or (Char is '|') or
      (Char is '(') or (Char is ')') or (Char is '[') or (Char is ']') or
      (Char is '*') or (Char is '+') or (Char is '?') or (Char is '{') or (Char is '}') then
      return '\\\\' .. Char
   end

   return Char
end

function path_param_regex(Route:table, ParamName:str):str
   path_fields = Route.interface.path
   if not path_fields or not path_fields[ParamName] then
      error('Path parameter {' .. ParamName .. '} is not declared in route path table: ' .. Route.path)
   end

   param_type = path_fields[ParamName].type ?? 'string'

   return choose param_type from
      'int'    -> '(-?[0-9]+)'
      'uint'   -> '([0-9]+)'
      'num'    -> '(-?(?:[0-9]+(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)'
      'float'  -> '(-?(?:[0-9]+(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)'
      'double' -> '(-?(?:[0-9]+(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)'
      'bool'   -> '(true|false|0|1)'
      'csv'    -> '([^\\\\/]+(?:,[^\\\\/]+)*)'
      'str'    -> '([^\\\\/]+)'
      'string' -> '([^\\\\/]+)'
      else     -> '([^\\\\/]+)'
   end
end

function path_to_regex(Route:table):str
   rx = '^'
   param_name = ''
   in_param = false

   Route.params = array<string> { }

   for i = 0, #Route.path - 1 do
      ch = Route.path:substr(i, i + 1)

      if in_param then
         if ch is '}' then
            if not param_name?? then
               error('Empty path parameter in route: ' .. Route.path)
            end

            Route.params:push(param_name)
            rx ..= path_param_regex(Route, param_name)
            param_name = ''
            in_param = false
         else
            param_name ..= ch
         end
      elseif ch is '{' then
         in_param = true
      else
         rx ..= regex_literal_char(ch)
      end
   end

   if in_param then
      error('Unterminated path parameter in route: ' .. Route.path)
   end

   rx ..= '$'
   Route.regex = rx
   return rx
end

function read_text_file(Path:str):str
   if mSys.AnalysePath(Path) != ERR_Okay then return '' end

   file = obj.new('file', { path=Path, flags=FL_READ })
   if file.size <= 0 then return '' end

   buffer = array<byte, file.size>
   check mSys.ReadFileToBuffer(Path, buffer)
   return buffer:getString()
end

function cpp_string(Value:any):str
   if Value is nil then return '""' end

   text = tostring(Value)
   out = '"'

   for i = 0, #text - 1 do
      ch = text:substr(i, i + 1)

      if ch is '\\' then out ..= '\\\\'
      elseif ch is '"' then out ..= '\\"'
      elseif ch is '\n' then out ..= '\\n'
      elseif ch is '\r' then out ..= '\\r'
      elseif ch is '\t' then out ..= '\\t'
      else out ..= ch
      end
   end

   out ..= '"'
   return out
end

function bool_literal(Value:any):str
   return Value ? 'true' :> 'false'
end

function sorted_field_names(Fields:table):array
   names = array<string> { }
   if not Fields then return names end

   for name, _ in pairs(Fields) do
      names:push(name)
   end

   names:sort()
   return names
end

function route_param_array(Name:str, Names:array, Fields:table):str
   out = f"static constexpr std::array<BackstageParam, {#Names}> {Name} = {{"

   if #Names > 0 then
      out ..= '\n'

      for i, name in Names do
         field = Fields[name]
         if i > 0 then out ..= ',\n' end
         out ..= f'   BackstageParam({cpp_string(name)}, {cpp_string(field.type ?? 'string')}, {cpp_string(field.desc ?? '')}, {cpp_string(field.default)}, {bool_literal(field.required)})'
      end

      out ..= '\n'
   end

   out ..= '};\n\n'
   return out
end

function route_path_param_names(Route:table):str
   name = Route.funcName .. '_path_param_names'
   out = f"static constexpr std::array<std::string_view, {#Route.params}> {name} = {{"

   if #Route.params > 0 then
      out ..= '\n'

      for i, param_name in Route.params do
         if i > 0 then out ..= ',\n' end
         out ..= '   ' .. cpp_string(param_name)
      end

      out ..= '\n'
   end

   out ..= '};\n\n'
   return out
end

function route_param_arrays(Route:table):str
   out = ''
   path_fields = Route.interface.path ?? {}
   query_fields = Route.interface.query ?? {}
   query_names = sorted_field_names(Route.interface.query)

   out ..= route_path_param_names(Route)
   out ..= route_param_array(Route.funcName .. '_path_params', Route.params, path_fields)
   out ..= route_param_array(Route.funcName .. '_query_params', query_names, query_fields)
   return out
end

function route_metadata(Route:table):str
   path_name = Route.funcName .. '_path_params'
   query_name = Route.funcName .. '_query_params'

   return 'BackstageRouteMetadata(\n' ..
      '         ' .. cpp_string(Route.interface.desc ?? '', '         ') .. ',\n' ..
      '         ' .. cpp_string(Route.interface.body ?? '') .. ',\n' ..
      '         ' .. cpp_string(Route.interface.returns ?? '') .. ',\n' ..
      '         ' .. cpp_string(Route.interface.transport ?? '') .. ',\n' ..
      f'         {path_name},\n' ..
      f'         {query_name})'
end

function route_table_entry(Route:table):str
   path_names = Route.funcName .. '_path_param_names'
   handler = Route.interface.transport is 'websocket' ? 'nullptr' :> Route.funcName

   return '   BackstageRoute(\n' ..
      '      ' .. cpp_string(Route.method) .. ',\n' ..
      '      ' .. cpp_string(Route.path) .. ',\n' ..
      '      "' .. Route.regex .. '",\n' ..
      '      ' .. handler .. ',\n' ..
      f'      {path_names},\n' ..
      '      ' .. route_metadata(Route) .. ')'
end

function route_handler_stub(Route:table):str
   proto = 'const BackstageRequest &Request, BackstageResponse &Response'

   out = '//********************************************************************************************************************\n'
   out ..= f'// @doc {Route.method} {Route.path} {Route.interface.desc}\n\n'
   out ..= f"static ERR {Route.funcName}({proto})\n{{\n"
   out ..= "   return ERR::NoSupport;\n"
   out ..= "}\n\n"
   return out
end

function append_missing_route_handler(Route:table)
   target_path = glWorkingPath .. Route.source
   content = read_text_file(target_path)
   signature = 'static ERR ' .. Route.funcName .. '('

   if content:find(signature) then return end

   local file:obj
   if content?? then
      file = obj.new('file', { path=target_path, flags=FL_WRITE })
      file.acSeek(0, SEEK_END)
      if not content:endsWith('\n') then file.acWrite('\n') end
   else
      file = obj.new('file', { path=target_path, flags=FL_NEW|FL_WRITE })
   end

   file.acWrite(route_handler_stub(Route))
end

----------------------------------------------------------------------------------------------------------------------

   glIncludes = {}
   glIncludeList = array<string> { }
   meta = ''

   for _, route in glRoutes do
      routes = route.path:split('/')
      route_path = 'routes/' .. routes[1] .. '.cpp'

      func_name = rx_func_name_chars.replace(route.method .. route.path, '_'):lower()
      if func_name:endsWith('_') then func_name = func_name[{0..-1}] end
      route.funcName = func_name
      route.source   = route_path

      path_to_regex(route)
      meta ..= route_param_arrays(route)

      if (route.interface.transport != 'websocket') and not glIncludes[route.source] then
         glIncludes[route.source] = true
         glIncludeList:push(route.source)
      end

      if route.interface.transport != 'websocket' then append_missing_route_handler(route) end
   end

   -- Write out the route table and include paths

   target_path = glWorkingPath .. 'routes.cpp'
   file = obj.new('file', { path=target_path, flags=FL_NEW|FL_WRITE })

   rtab = meta
   rtab ..= f"static std::array<BackstageRoute, {#glRoutes}> glRoutes = {{\n"
   for i, route in glRoutes do
      if i > 0 then rtab ..= ',\n' end
      rtab ..= route_table_entry(route)
   end
   rtab ..= '\n};\n'

   inc = ''
   for _, source in glIncludeList do
      inc ..= f'#include "{source}"\n'
   end

   route_accessor = "static std::span<BackstageRoute> backstage_routes();\n\n"
   route_accessor_impl = "static std::span<BackstageRoute> backstage_routes()\n{\n"
   route_accessor_impl ..= "   return glRoutes;\n"
   route_accessor_impl ..= "}\n"

   out = "// Auto-generated source code.  Regenerate with the backstage_routes CMake target.\n\n" ..
      route_accessor .. inc .. '\n' .. rtab .. '\n' .. route_accessor_impl
   file.acWrite(out)
