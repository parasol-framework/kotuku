--[[
Backstage REST Interface Configuration

Methods will generally either interrogate an existing resource or query it.

POST  Creates resources
PUT   Requests are idempotent and either update or create if the target doesn't exist
PATCH Should be used for updating existing resources

Route options:
   desc
   query
   returns

Types:
   json     - JSON object or array
   object   - JSON object
   array    - JSON array
   schema:* - JSON schema
   raw      - Raw data, text or binary
   stream   - Long-lived streaming protocol

Query options:
   type
   desc
   required

--]]

glRoutes = array<table> { }
glSelf = obj.find('self')
glWorkingPath = glSelf.workingPath

rx_func_name_chars <const> = <{ regex.new('[^A-Za-z0-9_]+') }>

function route(Method:str, Path:str, Interface:table)
   glRoutes:push({ method=Method, path=Path, interface=Interface })
end

----------------------------------------------------------------------------------------------------------------------
-- Agentic Interfaces

route('GET', '/agents/context', {
   desc = 'Return a compact runtime context bundle for AI agents: process info, loaded modules, object counts, active windows/surfaces, recent errors, and notable diagnostics.',
   query = {
      detail = { type='string', desc='One of summary, normal, verbose.' }
   },
   returns = 'object'
})

