--[[
Tuku Server Testing Suite

This test suite verifies all improvements made to the HTTP server including:
- Security enhancements (URL decoding, directory traversal protection, request limits)
- Performance improvements (file streaming, chunked reading, timeouts)
- Configuration improvements (MIME types, path validation, port validation)
- Error handling improvements (detailed error pages, client disconnect handling)
- Additional features (Range headers, HEAD method, verbose logging)
--]]

   include 'network'
   import 'net/httpserver'

   glPort = 18080
   glTestServer = nil
   glVerboseServer = nil
   glTestDir <const> = 'HostTemp:test_server_files'
   rxStatusLine <const> = <{ regex.new([[HTTP\/1\.[01]\s+(\d+)]]) }>
   rxContentLength <const> = <{ regex.new([[\r\ncontent-length:\s*([0-9]+)\r\n]], regex.ICASE) }>

@BeforeAll
function createTestFiles()
   err = mSys.DeleteFile(glTestDir .. '/')
   if (err != ERR_Okay) and (err != ERR_FileNotFound) and (err != ERR_Search) and (err != ERR_ResolvePath) then
      error('Failed to reset test directory: ' .. mSys.GetErrorMsg(err))
   end

   -- Create test directory if it doesn't exist
   if mSys.AnalysePath(glTestDir .. '/') != ERR_Okay then
      err = mSys.CreateFolder(glTestDir .. '/', 0)
      if err != ERR_Okay then
         error('Failed to create test directory: ' .. mSys.GetErrorMsg(err))
      end
   end

   -- Create test files
   smallFile = obj.new('file', { path = glTestDir .. '/small.txt', flags = FL_NEW|FL_WRITE })
   smallFile.acWrite('This is a small test file for HTTP server testing.')
   smallFile.free()

   -- Create a file large enough to force the streaming path without exceeding socket buffering in the test harness.
   largeFile = obj.new('file', { path = glTestDir .. '/large.txt', flags = FL_NEW|FL_WRITE })
   largeContent = string.rep('This line is repeated to create a large file for testing streaming functionality.\n', 300)
   global glLargeContentSize = #largeContent
   largeFile.acWrite(largeContent)
   largeFile.free()

   -- Create index.html
   indexFile = obj.new('file', { path = glTestDir .. '/index.html', flags = FL_NEW|FL_WRITE })
   indexFile.acWrite([[
<!DOCTYPE html>
<html>
<head><title>Test Index</title></head>
<body><h1>HTTP Server Test Index</h1><p>This is a test page.</p></body>
</html>
   ]])
   indexFile.free()

   -- Create files with different extensions for MIME type testing
   jsonFile = obj.new('file', { path = glTestDir .. '/test.json', flags = 'NEW|WRITE' })
   jsonFile.acWrite('{"test": "data", "server": "kotuku"}')
   jsonFile.free()

   cssFile = obj.new('file', { path = glTestDir .. '/test.css', flags = 'NEW|WRITE' })
   cssFile.acWrite('body { color: red; }')
   cssFile.free()

   -- Create subdirectory for path testing
   if mSys.AnalysePath(glTestDir .. '/subdir/') != ERR_Okay then
      mSys.CreateFolder(glTestDir .. '/subdir/', 0)
   end

   subFile = obj.new('file', { path = glTestDir .. '/subdir/nested.txt', flags = 'NEW|WRITE' })
   subFile.acWrite('This is a nested file.')
   subFile.free()

   glTestServer = hslib.start({
      port          = glPort,
      bind          = '127.0.0.1',
      folder        = glTestDir,
      verbose       = false,
      autoIndex     = true,
      fileChunkSize = 4096
   })

   glVerboseServer = hslib.start({
      port          = glPort + 1,
      bind          = '127.0.0.1',
      folder        = glTestDir,
      verbose       = true,
      autoIndex     = true,
      fileChunkSize = 4096
   })

   print('Test files created successfully')
end

@AfterAll
function cleanupTestFiles()
   if glVerboseServer then glVerboseServer.stop() end
   if glTestServer then glTestServer.stop() end

   err = mSys.DeleteFile(glTestDir .. '/')
end

function sendHttpRequest(Host:str, Port:num, Request:str):str
   local response = ''

   function isCompleteResponse(Response:str):bool
      local header_end = Response:find('\r\n\r\n')
      header_end ?? return false

      local headers = Response:substr(0, header_end + 2)
      local length_text = rxContentLength.extract(headers)
      length_text ?? return false

      local body = Response:substr(header_end + 4)
      return #body >= tonumber(length_text)
   end

   local client = obj.new('netsocket', {
      name = 'HTTPTestClient',
      feedback = function(Socket:obj, State:num)
         if State is NTC_CONNECTED then
            local err, len = Socket.acWrite(Request, #Request)
            if err != ERR_Okay then
               error('Failed to send HTTP request: ' .. mSys.GetErrorMsg(err))
            end
         elseif State is NTC_DISCONNECTED then
            Socket.acSignal()
         end
      end,
      incoming = function(Socket:obj)
         local buffer = string.alloc(32768)
         local err, bytes_read = Socket.acRead(buffer, 32768)
         if err is ERR_Okay then
            if bytes_read > 0 then response ..= buffer:substr(0, bytes_read) end
            if isCompleteResponse(response) then Socket.acSignal() end
         elseif err is ERR_Disconnected then
            Socket.acSignal()
         else
            error('Failed to read HTTP response: ' .. mSys.GetErrorMsg(err))
         end
      end
   })

   local proc = processing.new({ timeout = 5.0, signals = array<object> { client } })
   err = client.mtConnect(Host, Port, 3.0)
   if err != ERR_Okay then
      client.free()
      error('Failed to connect to server: ' .. mSys.GetErrorMsg(err))
   end

   err = proc.sleep()
   client.free()

   assert(err is ERR_Okay, 'HTTP request timed out or failed: ' .. mSys.GetErrorMsg(err))

   return response
end

function parseHttpResponse(Response:str):<str, str, str>
   if not Response or #Response is 0 then
      return nil, nil, nil
   end

   header_end = Response:find('\r\n\r\n')
   if not header_end then
      return nil, Response, ''
   end

   headers = Response:substr(0, header_end)
   body = Response:substr(header_end + 4)

   status_code = rxStatusLine.extract(headers) ?? '000'

   return status_code, headers, body
end

function isRejectedStatus(StatusCode:str):bool
   return StatusCode is '400' or StatusCode is '403' or StatusCode is '404'
end

-----------------------------------------------------------------------------------------------------------------------

@Test function BasicServerFunctionality()
   -- Test basic GET request
   request = "GET / HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, request)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '200', 'Expected 200 status, got: ' .. (statusCode or 'nil'))
   assert(body:find('<h1>HTTP Server Test Index</h1>'), 'Expected index.html content not found')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function UrlDecoding()
   -- Test URL with percent-encoded characters
   request = "GET /small.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, request)
   statusCode = parseHttpResponse(response)
   assert(statusCode is '200', 'Basic request failed')

   -- Test URL with encoded space (should work)
   encodedRequest = "GET /small%2Etxt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"  -- small.txt
   encodedResponse = sendHttpRequest('127.0.0.1', glPort, encodedRequest)
   encodedStatusCode, _, encodedBody = parseHttpResponse(encodedResponse)
   assert(encodedStatusCode is '200', 'URL decoding failed for encoded filename')
   assert(encodedBody:find('small test file'), 'Decoded file content incorrect')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function DirectoryTraversalProtection()
   -- Test basic directory traversal attempt
   traversalRequest = "GET /../../../etc/passwd HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, traversalRequest)
   statusCode = parseHttpResponse(response)
   assert(isRejectedStatus(statusCode), 'Directory traversal not blocked, got status: ' .. (statusCode or 'nil'))

   -- Test URL-encoded directory traversal attempts
   encodedTraversals = {
      'GET /%2e%2e/%2e%2e/test HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n',  -- ..%2e..
      'GET /%2E%2E/%2E%2E/test HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n',  -- ..%2E..
      'GET //etc/passwd HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n',          -- double slash
      'GET /%2f%2f/etc/passwd HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n'    -- encoded slashes
   }

   for i, traversalReq in ipairs(encodedTraversals) do
      resp = sendHttpRequest('127.0.0.1', glPort, traversalReq)
      code = parseHttpResponse(resp)
      assert(isRejectedStatus(code), 'Encoded traversal attempt ' .. i .. ' not blocked, got: ' .. (code or 'nil'))
   end
end

-----------------------------------------------------------------------------------------------------------------------

@Test function HeadMethodSupport()
   -- Test HEAD request
   headRequest = "HEAD /small.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, headRequest)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '200', 'HEAD request failed, got status: ' .. (statusCode or 'nil'))
   assert(headers:find('content-type'), 'Content-Type header missing in HEAD response')
   assert(#body is 0, 'HEAD request should not return body content')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function MimeTypeSupport()
   mimeTests = array<table> {
      { file = '/test.json', expectedType = 'application/json' },
      { file = '/test.css', expectedType = 'text/css' },
      { file = '/small.txt', expectedType = 'text/plain' },
      { file = '/index.html', expectedType = 'text/html' }
   }

   for test in values(mimeTests) do
      request = "GET " .. test.file .. " HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
      response = sendHttpRequest('127.0.0.1', glPort, request)

      statusCode, headers = parseHttpResponse(response)
      assert(statusCode is '200', 'Request for ' .. test.file .. ' failed')

      assert(headers:find('content-type: ' .. test.expectedType),
             'Wrong MIME type for ' .. test.file .. '. Expected: ' .. test.expectedType .. ', Headers: ' .. headers)
   end
end

-----------------------------------------------------------------------------------------------------------------------

@Test function ErrorPageGeneration()
   -- Test 404 error
   notFoundRequest = "GET /nonexistent.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, notFoundRequest)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '404', 'Expected 404 status for nonexistent file')
   assert(body:find('404 Not Found'), 'Error page title missing')
   assert(body:find('error-container'), 'Styled error page not generated')

   -- Test 405 method not allowed
   invalidMethodRequest = "POST / HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   methodResponse = sendHttpRequest('127.0.0.1', glPort, invalidMethodRequest)

   methodStatusCode, methodHeaders, methodBody = parseHttpResponse(methodResponse)
   assert(methodStatusCode is '405', 'Expected 405 status for invalid method')
   assert(methodHeaders:find('allow: GET, HEAD'), 'Allow header missing or incorrect')
   assert(methodBody:find('405 Method Not Allowed'), 'Method not allowed error page missing')
end

