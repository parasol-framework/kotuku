@Test function VerboseLogging()
   -- Make a request to generate log entries
   request = "GET /small.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort + 1, request)

   statusCode = parseHttpResponse(response)
   assert(statusCode is '200', 'Request with verbose logging failed')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function FileStreaming()
   -- Request the large file to test streaming
   request = "GET /large.txt HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, request)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '200', 'Large file request failed')
   assert(#body > 20000, 'Large file content too small, streaming may not have worked. Got: ' .. #body)
   assert(body:find('repeated to create a large file'), 'Large file content incorrect')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function RangeHeaderSupport()
   -- Test Range request for partial content
   rangeRequest = "GET /large.txt HTTP/1.1\r\nHost: localhost\r\nRange: bytes=0-999\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, rangeRequest)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '206', 'Range request should return 206 Partial Content, got: ' .. (statusCode or 'nil'))
   assert(headers:find('content-range'), 'Content-Range header missing')
   assert(headers:find('accept-ranges: bytes'), 'Accept-Ranges header missing or incorrect')
   assert(#body is 1000, 'Range request returned wrong amount of data. Expected 1000 bytes, got: ' .. #body)
end

-----------------------------------------------------------------------------------------------------------------------

@Test function OpenEndedRangeHeaderSupport()
   rangeRequest = "GET /large.txt HTTP/1.1\r\nHost: localhost\r\nRange: bytes=0-\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, rangeRequest)

   statusCode, headers, body = parseHttpResponse(response)
   expected_end = glLargeContentSize - 1
   assert(statusCode is '206',
      'Open-ended range request should return 206 Partial Content, got: ' .. (statusCode or 'nil'))
   assert(headers:find(f'content-range: bytes 0-{expected_end}/{glLargeContentSize}'),
      'Content-Range header incorrect: ' .. headers)
   assert(#body is glLargeContentSize,
      f'Open-ended range returned wrong amount of data. Expected {glLargeContentSize} bytes, got {#body}')
   assert(body:find('repeated to create a large file'), 'Open-ended range content incorrect')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function DirectoryListing()
   -- Test directory listing
   request = "GET /subdir/ HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
   response = sendHttpRequest('127.0.0.1', glPort, request)

   statusCode, headers, body = parseHttpResponse(response)
   assert(statusCode is '200', 'Directory listing request failed')
   assert(body:find('Directory listing'), 'Directory listing page not generated')
   assert(body:find('nested.txt'), 'File not listed in directory')
end
