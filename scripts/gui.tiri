                neutral = 'oklch(0.894 0 89.876)', mid='none',
                text='black', altText='white' },
      dark =  { type = 'dark', bkgd = 'oklch(0.289 0.030 185.119)', inverse = 'white',
                prime = 'oklch(0.652 0.166 127.067)', contrast = 'oklch(0.732 0.157 67.580)',
                neutral = 'oklch(0.277 0 89.876)', mid='none',
                text='white', altText='white' }
   },
   greenland = {
      light = { type = 'light', bkgd = 'oklch(0.994 0.008 157.097)', inverse = 'oklch(0.309 0.093 136.720)',
                prime = 'oklch(0.584 0.162 46.883)', contrast = 'oklch(0.532 0.138 127.325)',
                neutral = 'oklch(0.932 0.012 106.630)', mid='none',
                text='black', altText='white' },
      dark  = { type = 'dark', bkgd = 'oklch(0.309 0.093 136.720)', inverse = 'white',
                prime = 'oklch(0.584 0.162 46.883)', contrast = 'oklch(0.532 0.138 127.325)',
                neutral = 'oklch(0.402 0.015 107.041)', mid='none',
                text='white', altText='white' }
   },
   sunrise = {
      light = { type = 'light', bkgd = 'oklch(0.995 0.007 164.946)', inverse = 'oklch(0.560 0.019 196.622)',
                prime = 'oklch(0.634 0.185 40.533)', contrast = 'oklch(0.740 0.161 69.169)',
                neutral = 'oklch(0.894 0 89.876)', mid='none',
                text='black', altText='white' },
      dark=   { type = 'dark', bkgd = 'black', inverse = 'oklch(0.560 0.019 196.622)',
                prime = 'oklch(0.634 0.185 40.533)', contrast = 'oklch(0.740 0.161 69.169)',
                neutral = 'oklch(0.277 0 89.876)', mid='none',
                text='white', altText='white' }
   },
   candyfloss = {
      light = { type = 'light', bkgd = 'oklch(0.988 0.007 53.450)', inverse = 'oklch(0.443 0.041 204.992)',
                prime = 'oklch(0.768 0.105 167.447)', contrast = 'oklch(0.690 0.130 15.681)',
                neutral = 'oklch(0.894 0 89.876)',  mid='none',
                text='black', altText='white' },
      dark  = { type = 'dark', bkgd = 'oklch(0.443 0.041 204.992)', inverse = 'white',
                prime = 'oklch(0.768 0.105 167.447)', contrast = 'oklch(0.690 0.130 15.681)',
                neutral = 'oklch(0.277 0 89.876)', mid='none',
                text='white', altText='white' }
   }
}

   if not gui.theme then
      msg('No theme set, loading default from configuration file.')
      gui.theme = 'light' -- Default
      gui.paletteTheme = 'light' -- 'light' or 'dark' only
      gui.palette = gui.palettes.ocean

      if mSys.AnalysePath(glStyleConfig) is ERR_Okay then
         try
            local cfg = obj.new('config', { path=glStyleConfig })
            theme = [_*]cfg.mtReadValue('Style', 'Theme')
            palette = [_*]cfg.mtReadValue('Style', 'Palette')
            paletteTheme = [_*]cfg.mtReadValue('Style', 'PaletteTheme')
            gui.theme = theme
            if gui.palettes[palette] then
               gui.paletteTheme = gui.palettes?[palette]?[paletteTheme] ? paletteTheme :> 'light'
               gui.palette = gui.palettes[palette]
            end
         except ex
            print(f'Error in style configuration file {glStyleConfig}; delete to reset it')
            print(f'  Detail: {ex.message}')
         end
      else
         local file = obj.new('file', { path=glStyleConfig, flags=FL_WRITE|FL_NEW })
         file.acWrite("[Style]\nTheme = light\nPalette = ocean\nPaletteTheme = light\n")
      end
   end

