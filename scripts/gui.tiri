gui.style = gui.themes[gui.theme] -- Default user theme; but using gui.setTheme() is the preferred approach

gui.interface = {
   dpi       = 160,       -- Default DPI baseline
   fontSize  = 12,        -- Default font-size for everything (pt)
   iconTheme = 'Default', -- Named folder to load the icons from
   iconSize  = 20         -- Recommended default size for icons (px) and should be related to fontSize
}

   -- Convert font percentage sizes to their px size

   for font in values(gui.fonts) do
      if font.size then
         if rxFontSize.test(font.size) then
            pct = tonumber(rxFontSize.extract(font.size))
            font.size = math.floor(gui.interface.fontSize * (pct / 100))
         end
      end

      font.style ??= 'Regular'
   end
