function datetime.mtOffsetDateTime:instantEquals(Other:table):bool
   if datetime.isInstant(Other) then return self:instant() is Other end
   if datetime.isOffsetDateTime(Other) then return self:instant() is Other:instant() end
   datetime._invalidValue('Other must be an Instant or OffsetDateTime value.')
end

datetime.mtOffsetDateTime.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'OffsetDateTime')
   return tostring(fields.local_date_time) .. tostring(fields.offset)
end

datetime.mtOffsetDateTime.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'OffsetDateTime')
   local b = datetime._fields(B, 'OffsetDateTime')
   return offset_date_time_instant(A) is offset_date_time_instant(B) and a.offset is b.offset
end

datetime.mtOffsetDateTime.__lt = function(A:table, B:table):bool
   return offset_date_time_instant(A) < offset_date_time_instant(B)
end

datetime.mtOffsetDateTime.__le = function(A:table, B:table):bool
   return offset_date_time_instant(A) <= offset_date_time_instant(B)
end

datetime.mtOffsetDateTime.__add = function(A:table, B:table):table
   local fields = datetime._fields(A, 'OffsetDateTime')
   if datetime.isDuration(B) then
      return offset_date_time_from_instant(offset_date_time_instant(A) + B, fields.offset)
   end
   if datetime.isPeriod(B) then return new_offset_date_time(fields.local_date_time + B, fields.offset) end
   unsupported_operation(A, '+', B)
end

datetime.mtOffsetDateTime.__sub = function(A:table, B:table):table
   local fields = datetime._fields(A, 'OffsetDateTime')
   if datetime.isDuration(B) then
      return offset_date_time_from_instant(offset_date_time_instant(A) - B, fields.offset)
   end
   if datetime.isPeriod(B) then return new_offset_date_time(fields.local_date_time - B, fields.offset) end
   if datetime.isOffsetDateTime(B) then return offset_date_time_instant(A) - offset_date_time_instant(B) end
   unsupported_operation(A, '-', B)
end

function datetime.mtPeriod:normalise():table
   local fields = datetime._fields(self, 'Period')
   local total_months = fields.years * 12 + fields.months
   local years = math.floor(total_months / 12)
   local months = total_months - years * 12
   return new_period(years, months, 0, fields.weeks * 7 + fields.days)
end

datetime.mtPeriod.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'Period')
   local text = 'P'
   if fields.years != 0 then text ..= tostring(fields.years) .. 'Y' end
   if fields.months != 0 then text ..= tostring(fields.months) .. 'M' end
   if fields.weeks != 0 then text ..= tostring(fields.weeks) .. 'W' end
   if fields.days != 0 then text ..= tostring(fields.days) .. 'D' end
   if text is 'P' then text ..= '0D' end
   return text
end

datetime.mtPeriod.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Period')
   local b = datetime._fields(B, 'Period')
   return a.years is b.years and a.months is b.months and a.weeks is b.weeks and a.days is b.days
end

datetime.mtPeriod.__add = function(A:table, B:table):table
   local a = datetime._fields(A, 'Period')
   if datetime.isPeriod(B) then
      local b = datetime._fields(B, 'Period')
      return new_period(a.years + b.years, a.months + b.months, a.weeks + b.weeks, a.days + b.days)
   end
   unsupported_operation(A, '+', B)
end

datetime.mtPeriod.__sub = function(A:table, B:table):table
   local a = datetime._fields(A, 'Period')
   if datetime.isPeriod(B) then
      local b = datetime._fields(B, 'Period')
      return new_period(a.years - b.years, a.months - b.months, a.weeks - b.weeks, a.days - b.days)
   end
   unsupported_operation(A, '-', B)
end

datetime.mtPeriod.__unm = function(Self:table):table
   local fields = datetime._fields(Self, 'Period')
   return new_period(-fields.years, -fields.months, -fields.weeks, -fields.days)
end

function datetime.mtInterval:start():table
   return datetime._fields(self, 'Interval').start
end

function datetime.mtInterval:stop():table
   return datetime._fields(self, 'Interval').stop
end

function datetime.mtInterval:duration():table
   local fields = datetime._fields(self, 'Interval')
   return fields.stop - fields.start
end

function datetime.mtInterval:contains(Instant:table):bool
   if not datetime.isInstant(Instant) then datetime._invalidValue('Instant must be an Instant value.') end
   local fields = datetime._fields(self, 'Interval')
   return fields.start <= Instant and Instant < fields.stop
end

function datetime.mtInterval:overlaps(Other:table):bool
   if not datetime.isInterval(Other) then datetime._invalidValue('Other must be an Interval value.') end
   local fields = datetime._fields(self, 'Interval')
   local other = datetime._fields(Other, 'Interval')
   return fields.start < other.stop and other.start < fields.stop
end

function datetime.mtInterval:intersection(Other:table):table
   if not datetime.isInterval(Other) then datetime._invalidValue('Other must be an Interval value.') end
   local fields = datetime._fields(self, 'Interval')
   local other = datetime._fields(Other, 'Interval')
   local start = fields.start < other.start ? other.start :> fields.start
   local stop = fields.stop < other.stop ? fields.stop :> other.stop
   if stop < start then stop = start end
   return new_interval(start, stop)
end

function datetime.mtInterval:union(Other:table):table
   if not datetime.isInterval(Other) then datetime._invalidValue('Other must be an Interval value.') end
   local fields = datetime._fields(self, 'Interval')
   local other = datetime._fields(Other, 'Interval')
   if fields.stop < other.start or other.stop < fields.start then
      datetime._invalidValue('Cannot union separate intervals.')
   end

   local start = fields.start < other.start ? fields.start :> other.start
   local stop = fields.stop < other.stop ? other.stop :> fields.stop
   return new_interval(start, stop)
end

function datetime.mtInterval:isEmpty():bool
   local fields = datetime._fields(self, 'Interval')
   return fields.start is fields.stop
end

datetime.mtInterval.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'Interval')
   return tostring(fields.start) .. '/' .. tostring(fields.stop)
end

datetime.mtInterval.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Interval')
   local b = datetime._fields(B, 'Interval')
   return a.start is b.start and a.stop is b.stop
end

function datetime.mtZone:id():str
   return datetime._fields(self, 'Zone').id
end

function datetime.mtZone:nativeId():str
   return datetime._fields(self, 'Zone').native_id
end

function datetime.mtZone:source():str
   return datetime._fields(self, 'Zone').source
end

function datetime.mtZone:isFallback():bool
   return datetime._fields(self, 'Zone').is_fallback
end

function datetime.mtZone:offsetAt(Instant:table):table
   require_instant(Instant)
   return datetime._fields(self, 'Zone').offset
end

function datetime.mtZone:nameAt(Instant:table):str
   require_instant(Instant)
   return datetime._fields(self, 'Zone').id
end

function datetime.mtZone:nextTransition(Instant:table):any
   require_instant(Instant)
   return nil
end

function datetime.mtZone:previousTransition(Instant:table):any
   require_instant(Instant)
   return nil
end

datetime.mtZone.__tostring = function(Self:table):str
   return datetime._fields(Self, 'Zone').id
end

datetime.mtZone.__eq = function(A:table, B:table):bool
   return datetime._fields(A, 'Zone').id is datetime._fields(B, 'Zone').id
end

function datetime.mtClock:instant():table
   local fields = datetime._fields(self, 'Clock')

   if fields.kind is 'fixed' then return fields.instant end
   if fields.kind is 'offset' then return fields.base_clock:instant() + fields.offset end
   if fields.kind is 'system' then
      local time_obj = obj.new('time')
      check time_obj.acQuery() -- Get epoch time
      return instant_from_system_micros(time_obj.systemTime)
   end

   datetime._invalidValue(f"Unknown Clock kind '{fields.kind}'.")
end

function datetime.mtClock:today(Zone:table):table
   return self:localDateTime(Zone):date()
end

function datetime.mtClock:localDateTime(Zone:table):table
   Zone ??= datetime.zone.local()
   require_zone(Zone)

   local instant = self:instant()
   local instant_fields = datetime._fields(instant, 'Instant')
   local offset_fields = datetime._fields(Zone:offsetAt(instant), 'Offset')
   local date_fields, time_fields = epoch_second_to_local(instant_fields.epoch_second + offset_fields.seconds,
      instant_fields.nano)
   return new_local_date_time(date_fields.year, date_fields.month, date_fields.day, time_fields.hour,
      time_fields.minute, time_fields.second, time_fields.nano)
end

function datetime.mtClock:zonedDateTime(Zone:table):table
   datetime._notReady('clock.zonedDateTime')
end

datetime.mtClock.__tostring = function(Self:table):str
   return f"datetime.Clock({datetime._fields(Self, 'Clock').kind})"
end

----------------------------------------------------------------------------------------------------------------------
-- Future-stage public shells.

datetime.zone = make_constructor('zone')
datetime.zone.local = make_not_ready('zone.local')
datetime.zone.utc = function():table
   return new_zone_utc()
end

datetime.zonedDateTime = make_constructor('zonedDateTime')
datetime.zonedDateTime.from = make_not_ready('zonedDateTime.from')
datetime.zonedDateTime.parse = make_not_ready('zonedDateTime.parse')

datetime.clock = {
   system = function():table
      return new_clock('system', {})
   end,
   fixed = function(Instant:table):table
      require_instant(Instant)
      return new_clock('fixed', { instant = Instant })
   end,
   offset = function(BaseClock:table, Duration:table):table
      require_clock(BaseClock)
      require_duration(Duration)
      return new_clock('offset', { base_clock = BaseClock, offset = Duration })
   end
}
datetime.resolve = {
   reject = datetime._makeValue('Resolver', { name = 'reject' }),
   earlier = datetime._makeValue('Resolver', { name = 'earlier' }),
   later = datetime._makeValue('Resolver', { name = 'later' }),
   skip = datetime._makeValue('Resolver', { name = 'skip' }),
   compatible = datetime._makeValue('Resolver', { name = 'compatible' })
}

datetime.now = function(Clock:table):table
   Clock ??= datetime.clock.system()
   require_clock(Clock)
   return Clock:instant()
end

datetime.today = function(Zone:table, Clock:table):table
   Zone ??= datetime.zone.local()
   Clock ??= datetime.clock.system()
   require_zone(Zone)
   require_clock(Clock)
   return Clock:today(Zone)
end

----------------------------------------------------------------------------------------------------------------------

datetime.isInstant        = function(Value:any):bool return datetime._isValue(Value, 'Instant') end

datetime.isDuration       = function(Value:any):bool return datetime._isValue(Value, 'Duration') end

datetime.isOffset         = function(Value:any):bool return datetime._isValue(Value, 'Offset') end

datetime.isLocalDate      = function(Value:any):bool return datetime._isValue(Value, 'LocalDate') end

datetime.isLocalTime      = function(Value:any):bool return datetime._isValue(Value, 'LocalTime') end

datetime.isLocalDateTime  = function(Value:any):bool return datetime._isValue(Value, 'LocalDateTime') end

datetime.isOffsetDateTime = function(Value:any):bool return datetime._isValue(Value, 'OffsetDateTime') end

datetime.isZone           = function(Value:any):bool return datetime._isValue(Value, 'Zone') end

datetime.isZonedDateTime  = function(Value:any):bool return datetime._isValue(Value, 'ZonedDateTime') end

datetime.isPeriod         = function(Value:any):bool return datetime._isValue(Value, 'Period') end

datetime.isInterval       = function(Value:any):bool return datetime._isValue(Value, 'Interval') end

datetime.isClock          = function(Value:any):bool return datetime._isValue(Value, 'Clock') end

datetime.isResolver       = function(Value:any):bool return datetime._isValue(Value, 'Resolver') end
