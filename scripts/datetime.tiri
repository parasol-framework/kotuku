local local_date_time_with = function(Self:table, KV:table):table
   datetime._requireTable('fields', KV)
   local fields = datetime._fields(Self, 'LocalDateTime')
   local date_fields = datetime._fields(fields.date, 'LocalDate')
   local time_fields = datetime._fields(fields.time, 'LocalTime')
   return new_local_date_time(KV.year ?? date_fields.year, KV.month ?? date_fields.month, KV.day ?? date_fields.day,
      KV.hour ?? time_fields.hour, KV.minute ?? time_fields.minute, KV.second ?? time_fields.second,
