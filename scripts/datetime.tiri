-- Metatable methods.

function datetime.mtInstant:toUnixSeconds():num
   return datetime._fields(self, 'Instant').epoch_second
end

function datetime.mtInstant:toUnixMillis():num
   local fields = datetime._fields(self, 'Instant')
   return fields.epoch_second * 1000 + math.floor(fields.nano / 1000000)
end

function datetime.mtInstant:toUnixNanos():num
   local fields = datetime._fields(self, 'Instant')
   return fields.epoch_second * NANOS_PER_SECOND + fields.nano
end

datetime.mtInstant.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'Instant')
   local date_fields, time_fields = epoch_second_to_local(fields.epoch_second, fields.nano)
   return f"{format_year(date_fields.year)}-{pad_int(date_fields.month, 2)}-{pad_int(date_fields.day, 2)}T" ..
      f"{pad_int(time_fields.hour, 2)}:{pad_int(time_fields.minute, 2)}:{pad_int(time_fields.second, 2)}" ..
      format_nano(time_fields.nano) .. 'Z'
end

datetime.mtInstant.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Instant')
   local b = datetime._fields(B, 'Instant')
   return a.epoch_second is b.epoch_second and a.nano is b.nano
end

datetime.mtInstant.__lt = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Instant')
   local b = datetime._fields(B, 'Instant')
   return compare_pair(a.epoch_second, a.nano, b.epoch_second, b.nano) < 0
end

datetime.mtInstant.__le = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Instant')
   local b = datetime._fields(B, 'Instant')
   return compare_pair(a.epoch_second, a.nano, b.epoch_second, b.nano) <= 0
end

datetime.mtInstant.__add = function(A:table, B:table):table
   local a = datetime._fields(A, 'Instant')
   if datetime.isDuration(B) then
      local b = datetime._fields(B, 'Duration')
      return new_instant(a.epoch_second + b.seconds, a.nano + b.nano)
   end
   unsupported_operation(A, '+', B)
end

datetime.mtInstant.__sub = function(A:table, B:table):table
   local a = datetime._fields(A, 'Instant')
   if datetime.isDuration(B) then
      local b = datetime._fields(B, 'Duration')
      return new_instant(a.epoch_second - b.seconds, a.nano - b.nano)
   end
   if datetime.isInstant(B) then
      local b = datetime._fields(B, 'Instant')
      return new_duration(a.epoch_second - b.epoch_second, a.nano - b.nano)
   end
   unsupported_operation(A, '-', B)
end

datetime.mtInstant['until'] = function(Self:table, Other:table):table
   if not datetime.isInstant(Other) then datetime._invalidValue('Other must be an Instant value.') end
   return Other - Self
end

function datetime.mtDuration:totalSeconds():num
   local fields = datetime._fields(self, 'Duration')
   return fields.seconds + fields.nano / NANOS_PER_SECOND
end

function datetime.mtDuration:totalMillis():num
   local fields = datetime._fields(self, 'Duration')
   return fields.seconds * 1000 + fields.nano / 1000000
end

datetime.mtDuration.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'Duration')
   local seconds = fields.seconds
   local nano = fields.nano
   local negative = seconds < 0
   if negative then
      seconds = -seconds - (nano > 0 ? 1 :> 0)
      nano = nano > 0 ? NANOS_PER_SECOND - nano :> 0
   end

   local hours = math.floor(seconds / 3600)
   seconds -= hours * 3600
   local minutes = math.floor(seconds / 60)
   seconds -= minutes * 60

   local text = negative ? '-PT' :> 'PT'
   if hours != 0 then text ..= tostring(hours) .. 'H' end
   if minutes != 0 then text ..= tostring(minutes) .. 'M' end
   if seconds != 0 or nano != 0 or (hours is 0 and minutes is 0) then
      text ..= tostring(seconds) .. format_nano(nano) .. 'S'
   end
   return text
end

datetime.mtDuration.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Duration')
   local b = datetime._fields(B, 'Duration')
   return a.seconds is b.seconds and a.nano is b.nano
end

datetime.mtDuration.__lt = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Duration')
   local b = datetime._fields(B, 'Duration')
   return compare_pair(a.seconds, a.nano, b.seconds, b.nano) < 0
end

datetime.mtDuration.__le = function(A:table, B:table):bool
   local a = datetime._fields(A, 'Duration')
   local b = datetime._fields(B, 'Duration')
   return compare_pair(a.seconds, a.nano, b.seconds, b.nano) <= 0
end

datetime.mtDuration.__add = function(A:table, B:table):table
   local a = datetime._fields(A, 'Duration')
   if datetime.isDuration(B) then
      local b = datetime._fields(B, 'Duration')
      return new_duration(a.seconds + b.seconds, a.nano + b.nano)
   end
   unsupported_operation(A, '+', B)
end

datetime.mtDuration.__sub = function(A:table, B:table):table
   local a = datetime._fields(A, 'Duration')
   if datetime.isDuration(B) then
      local b = datetime._fields(B, 'Duration')
      return new_duration(a.seconds - b.seconds, a.nano - b.nano)
   end
   unsupported_operation(A, '-', B)
end

datetime.mtDuration.__unm = function(Self:table):table
   local fields = datetime._fields(Self, 'Duration')
   return new_duration(-fields.seconds, -fields.nano)
end

function datetime.mtOffset:totalSeconds():num
   return datetime._fields(self, 'Offset').seconds
end

datetime.mtOffset.__unm = function(Self:table):table
   return new_offset(-datetime._fields(Self, 'Offset').seconds)
end

datetime.mtOffset.__tostring = function(Self:table):str
   local seconds = datetime._fields(Self, 'Offset').seconds
   if seconds is 0 then return 'Z' end

   local sign = seconds < 0 ? '-' :> '+'
   if seconds < 0 then seconds = -seconds end
   local hours = math.floor(seconds / 3600)
   local minutes = math.floor((seconds - hours * 3600) / 60)
   return sign .. pad_int(hours, 2) .. ':' .. pad_int(minutes, 2)
end

datetime.mtOffset.__eq = function(A:table, B:table):bool
   return datetime._fields(A, 'Offset').seconds is datetime._fields(B, 'Offset').seconds
end

datetime.mtOffset.__lt = function(A:table, B:table):bool
   return datetime._fields(A, 'Offset').seconds < datetime._fields(B, 'Offset').seconds
end

datetime.mtOffset.__le = function(A:table, B:table):bool
   return datetime._fields(A, 'Offset').seconds <= datetime._fields(B, 'Offset').seconds
end

