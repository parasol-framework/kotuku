datetime.mtLocalDate.__add = function(A:table, B:table):table
   local a = datetime._fields(A, 'LocalDate')
   if datetime.isPeriod(B) then
      local fields = date_plus_period_fields(a, datetime._fields(B, 'Period'), 1)
      return new_local_date(fields.year, fields.month, fields.day)
   end
   unsupported_operation(A, '+', B)
end

datetime.mtLocalDate.__sub = function(A:table, B:table):table
   local a = datetime._fields(A, 'LocalDate')
   if datetime.isPeriod(B) then
      local fields = date_plus_period_fields(a, datetime._fields(B, 'Period'), -1)
      return new_local_date(fields.year, fields.month, fields.day)
   end
   if datetime.isLocalDate(B) then
      local b = datetime._fields(B, 'LocalDate')
      return new_period(0, 0, 0, days_from_civil(a.year, a.month, a.day) - days_from_civil(b.year, b.month, b.day))
   end
   unsupported_operation(A, '-', B)
end

datetime.mtLocalDate.__tostring = function(Self:table):str
