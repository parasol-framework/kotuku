datetime.mtLocalDateTime.__add = function(A:table, B:table):table
   local a = datetime._fields(A, 'LocalDateTime')
   local date_fields = datetime._fields(a.date, 'LocalDate')
   local time_fields = datetime._fields(a.time, 'LocalTime')

   if datetime.isDuration(B) then
      local new_date_fields, new_time_fields =
         local_date_time_plus_duration_fields(date_fields, time_fields, datetime._fields(B, 'Duration'), 1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         new_time_fields.hour, new_time_fields.minute, new_time_fields.second, new_time_fields.nano)
   end

   if datetime.isPeriod(B) then
      local new_date_fields = date_plus_period_fields(date_fields, datetime._fields(B, 'Period'), 1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         time_fields.hour, time_fields.minute, time_fields.second, time_fields.nano)
   end

   unsupported_operation(A, '+', B)
end

datetime.mtLocalDateTime.__sub = function(A:table, B:table):table
   local a = datetime._fields(A, 'LocalDateTime')
   local date_fields = datetime._fields(a.date, 'LocalDate')
   local time_fields = datetime._fields(a.time, 'LocalTime')

   if datetime.isDuration(B) then
      local new_date_fields, new_time_fields =
         local_date_time_plus_duration_fields(date_fields, time_fields, datetime._fields(B, 'Duration'), -1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         new_time_fields.hour, new_time_fields.minute, new_time_fields.second, new_time_fields.nano)
   end

   if datetime.isPeriod(B) then
      local new_date_fields = date_plus_period_fields(date_fields, datetime._fields(B, 'Period'), -1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         time_fields.hour, time_fields.minute, time_fields.second, time_fields.nano)
   end

   unsupported_operation(A, '-', B)
end

datetime.mtLocalDateTime.__tostring = function(Self:table):str
   local fields = datetime._fields(Self, 'LocalDateTime')
   return tostring(fields.date) .. 'T' .. tostring(fields.time)
end

datetime.mtLocalDateTime.__eq = function(A:table, B:table):bool
   local a = datetime._fields(A, 'LocalDateTime')
   local b = datetime._fields(B, 'LocalDateTime')
   return a.date is b.date and a.time is b.time
end

datetime.mtLocalDateTime.__lt = function(A:table, B:table):bool
   local a = datetime._fields(A, 'LocalDateTime')
   local b = datetime._fields(B, 'LocalDateTime')
   local date_compare = compare_date_fields(datetime._fields(a.date, 'LocalDate'),
      datetime._fields(b.date, 'LocalDate'))
   if date_compare != 0 then return date_compare < 0 end
   return compare_time_fields(datetime._fields(a.time, 'LocalTime'), datetime._fields(b.time, 'LocalTime')) < 0
end

datetime.mtLocalDateTime.__le = function(A:table, B:table):bool
   return A < B or A is B
end

