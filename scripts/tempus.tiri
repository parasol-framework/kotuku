tempus.localDateTime.from = function(KV:table):table
   tempus._requireTable('localDateTime', KV)
   if KV.date != nil and KV.time != nil then
      return new_local_date_time_from_parts(KV.date, KV.time)
   end
   return new_local_date_time(KV.year, KV.month, KV.day, KV.hour ?? 0, KV.minute ?? 0, KV.second ?? 0, KV.nano ?? 0)
end

@Doc(text=[[
@desc Parse an ISO local date-time
