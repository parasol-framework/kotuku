   return new_period(0, 0, 0, Days)
end

@Doc(text=[[
@desc Parse an ISO date period
@input Period text
@result Period value
]])
tempus.period.parse = function(Text:str):table
   if type(Text) != 'string' then tempus._syntaxError('Period text must be a string.') end

   sign_text, years_text, months_text, weeks_text, days_text = rx_period.extract(Text)
   if (years_text is nil or years_text is '') and (months_text is nil or months_text is '') and
      (weeks_text is nil or weeks_text is '') and (days_text is nil or days_text is '') then
      tempus._syntaxError(f"Invalid Period string '{Text}'.")
   end

   sign = sign_text is '-' ? -1 :> 1
   return new_period(sign * tonumber(years_text ?? '0'), sign * tonumber(months_text ?? '0'),
      sign * tonumber(weeks_text ?? '0'), sign * tonumber(days_text ?? '0'))
end

@Doc(text=[[
@desc Create a period from field values
@input Table with years, months, weeks, or days
@result Period value
]])
getmetatable(tempus.period).__call = function(Self, KV:any):table
   tempus._requireTable('period', KV)
   return new_period(KV.years ?? 0, KV.months ?? 0, KV.weeks ?? 0, KV.days ?? 0)
end

tempus.interval = make_constructor('interval')
@Doc(text=[[
@desc Create an interval from field values
@input Table with start and stop instants
@result Interval value
]])
tempus.interval.from = function(KV:table):table
   tempus._requireTable('interval', KV)
   return new_interval(KV.start, KV.stop)
end

@Doc(text=[[
@desc Create an interval from a start and duration
@input Start instant
@input Duration value
@result Interval value
]])
tempus.interval.fromStartAndDuration = function(Start:table, Duration:table):table
   start_fields = require_instant(Start)
   duration_fields = require_duration(Duration)
   return new_interval(Start, new_instant(start_fields.epoch_second + duration_fields.seconds,
      start_fields.nano + duration_fields.nano))
end

@Doc(text=[[
@desc Create an interval
@input Start instant
@input Stop instant
@result Interval value
]])
getmetatable(tempus.interval).__call = function(Self, Start:any, Stop:any):table
   return new_interval(Start, Stop)
end

----------------------------------------------------------------------------------------------------------------------
-- Metatable methods.

@Doc(text=[[
@desc Return Unix epoch seconds
@result Seconds since the Unix epoch
]])
function tempus.mtInstant:toUnixSeconds():num
   return tempus._fields(self, 'Instant').epoch_second
end

@Doc(text=[[
@desc Return Unix epoch milliseconds
@result Milliseconds since the Unix epoch
]])
function tempus.mtInstant:toUnixMillis():num
   fields = tempus._fields(self, 'Instant')
   return fields.epoch_second * 1000 + math.floor(fields.nano / 1000000)
end

@Doc(text=[[
@desc Return Unix epoch nanoseconds
@result Nanoseconds since the Unix epoch
]])
function tempus.mtInstant:toUnixNanos():num
   fields = tempus._fields(self, 'Instant')
   return fields.epoch_second * NANOS_PER_SECOND + fields.nano
end

@Doc(text=[[
@desc Convert this instant to text
@result ISO instant text
]])
tempus.mtInstant.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'Instant')
   date_fields, time_fields = epoch_second_to_local(fields.epoch_second, fields.nano)
   return f"{format_year(date_fields.year)}-{pad_int(date_fields.month, 2)}-{pad_int(date_fields.day, 2)}T" ..
      f"{pad_int(time_fields.hour, 2)}:{pad_int(time_fields.minute, 2)}:{pad_int(time_fields.second, 2)}" ..
      format_nano(time_fields.nano) .. 'Z'
end

@Doc(text=[[
@desc Compare instants for equality
@input First instant
@input Second instant
@result True when equal
]])
tempus.mtInstant.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'Instant')
   b = tempus._fields(B, 'Instant')
   return a.epoch_second is b.epoch_second and a.nano is b.nano
end

@Doc(text=[[
@desc Compare instant ordering
@input First instant
@input Second instant
@result True when first is earlier
]])
tempus.mtInstant.__lt = function(A:table, B:table):bool
   a = tempus._fields(A, 'Instant')
   b = tempus._fields(B, 'Instant')
   return compare_pair(a.epoch_second, a.nano, b.epoch_second, b.nano) < 0
end

@Doc(text=[[
@desc Compare instant ordering inclusively
@input First instant
@input Second instant
@result True when first is not later
]])
tempus.mtInstant.__le = function(A:table, B:table):bool
   a = tempus._fields(A, 'Instant')
   b = tempus._fields(B, 'Instant')
   return compare_pair(a.epoch_second, a.nano, b.epoch_second, b.nano) <= 0
end

@Doc(text=[[
@desc Add a duration to an instant
@input Instant value
@input Duration value
@result Instant value
]])
tempus.mtInstant.__add = function(A:table, B:table):table
   a = tempus._fields(A, 'Instant')
   if tempus.isDuration(B) then
      b = tempus._fields(B, 'Duration')
      return new_instant(a.epoch_second + b.seconds, a.nano + b.nano)
   end
   unsupported_operation(A, '+', B)
end

@Doc(text=[[
@desc Subtract a duration or instant
@input Instant value
@input Duration or Instant value
@result Instant or Duration value
]])
tempus.mtInstant.__sub = function(A:table, B:table):table
   a = tempus._fields(A, 'Instant')
   if tempus.isDuration(B) then
      b = tempus._fields(B, 'Duration')
      return new_instant(a.epoch_second - b.seconds, a.nano - b.nano)
   end
   if tempus.isInstant(B) then
      b = tempus._fields(B, 'Instant')
      return new_duration(a.epoch_second - b.epoch_second, a.nano - b.nano)
   end
   unsupported_operation(A, '-', B)
end

@Doc(text=[[
@desc Return the duration until another instant
@input Target instant
@result Duration value
]])
function tempus.mtInstant:durationUntil(Other:table):table
   if not tempus.isInstant(Other) then tempus._invalidValue('Other must be an Instant value.') end
   return Other - self
end

@Doc(text=[[
@desc Convert this instant to a zoned date-time
@input Target time zone
@result ZonedDateTime value
]])
function tempus.mtInstant:toZonedDateTime(Zone:table):table
   return new_zoned_date_time(self, Zone)
end

@Doc(text=[[
@desc Format this instant
@input Format pattern
@result Formatted text
]])
function tempus.mtInstant:format(Pattern:any):str
   fields = tempus._fields(self, 'Instant')
   date_fields, time_fields = epoch_second_to_local(fields.epoch_second, fields.nano)
   return format_local_fields('Instant', date_fields, time_fields, tempus.offset.utc(), 'UTC', Pattern)
end

@Doc(text=[[
@desc Return the duration in seconds
@result Total seconds
]])
function tempus.mtDuration:totalSeconds():num
   fields = tempus._fields(self, 'Duration')
   return fields.seconds + fields.nano / NANOS_PER_SECOND
end

@Doc(text=[[
@desc Return the duration in milliseconds
@result Total milliseconds
]])
function tempus.mtDuration:totalMillis():num
   fields = tempus._fields(self, 'Duration')
   return fields.seconds * 1000 + fields.nano / 1000000
end

@Doc(text=[[
@desc Convert this duration to text
@result ISO duration text
]])
tempus.mtDuration.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'Duration')
   seconds = fields.seconds
   nano = fields.nano
   negative = seconds < 0
   if negative then
      seconds = -seconds - (nano > 0 ? 1 :> 0)
      nano = nano > 0 ? NANOS_PER_SECOND - nano :> 0
   end

   hours = math.floor(seconds / 3600)
   seconds -= hours * 3600
   minutes = math.floor(seconds / 60)
   seconds -= minutes * 60

   local text = negative ? '-PT' :> 'PT'
   if hours != 0 then text ..= tostring(hours) .. 'H' end
   if minutes != 0 then text ..= tostring(minutes) .. 'M' end
   if seconds != 0 or nano != 0 or (hours is 0 and minutes is 0) then
      text ..= tostring(seconds) .. format_nano(nano) .. 'S'
   end
   return text
end

@Doc(text=[[
@desc Compare durations for equality
@input First duration
