   Resolver ??= tempus.resolve.compatible
   return resolve_local_date_time(self, Zone, Resolver)
end

@Doc(text=[[
@desc Add a duration or period
@input LocalDateTime value
@input Duration or Period value
@result LocalDateTime value
]])
tempus.mtLocalDateTime.__add = function(A:table, B:table):table
   a = tempus._fields(A, 'LocalDateTime')
   date_fields = tempus._fields(a.date, 'LocalDate')
   time_fields = tempus._fields(a.time, 'LocalTime')

   if tempus.isDuration(B) then
      new_date_fields, new_time_fields =
         local_date_time_plus_duration_fields(date_fields, time_fields, tempus._fields(B, 'Duration'), 1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         new_time_fields.hour, new_time_fields.minute, new_time_fields.second, new_time_fields.nano)
   end

   if tempus.isPeriod(B) then
      new_date_fields = date_plus_period_fields(date_fields, tempus._fields(B, 'Period'), 1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         time_fields.hour, time_fields.minute, time_fields.second, time_fields.nano)
   end

   unsupported_operation(A, '+', B)
end

@Doc(text=[[
@desc Subtract a duration or period
@input LocalDateTime value
@input Duration or Period value
@result LocalDateTime value
]])
tempus.mtLocalDateTime.__sub = function(A:table, B:table):table
   a = tempus._fields(A, 'LocalDateTime')
   date_fields = tempus._fields(a.date, 'LocalDate')
   time_fields = tempus._fields(a.time, 'LocalTime')

   if tempus.isDuration(B) then
      new_date_fields, new_time_fields =
         local_date_time_plus_duration_fields(date_fields, time_fields, tempus._fields(B, 'Duration'), -1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         new_time_fields.hour, new_time_fields.minute, new_time_fields.second, new_time_fields.nano)
   end

   if tempus.isPeriod(B) then
      new_date_fields = date_plus_period_fields(date_fields, tempus._fields(B, 'Period'), -1)
      return new_local_date_time(new_date_fields.year, new_date_fields.month, new_date_fields.day,
         time_fields.hour, time_fields.minute, time_fields.second, time_fields.nano)
   end

   unsupported_operation(A, '-', B)
end

@Doc(text=[[
@desc Convert this local date-time to text
@result ISO local date-time text
]])
tempus.mtLocalDateTime.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'LocalDateTime')
   return f'{fields.date}T{fields.time}'
end

@Doc(text=[[
@desc Compare local date-times for equality
@input First local date-time
@input Second local date-time
@result True when equal
]])
tempus.mtLocalDateTime.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'LocalDateTime')
   b = tempus._fields(B, 'LocalDateTime')
   return a.date is b.date and a.time is b.time
end

@Doc(text=[[
@desc Compare local date-time ordering
@input First local date-time
@input Second local date-time
@result True when first is earlier
]])
tempus.mtLocalDateTime.__lt = function(A:table, B:table):bool
   a = tempus._fields(A, 'LocalDateTime')
   b = tempus._fields(B, 'LocalDateTime')
   date_compare = compare_date_fields(tempus._fields(a.date, 'LocalDate'),
      tempus._fields(b.date, 'LocalDate'))
   if date_compare != 0 then return date_compare < 0 end
   return compare_time_fields(tempus._fields(a.time, 'LocalTime'), tempus._fields(b.time, 'LocalTime')) < 0
end

@Doc(text=[[
@desc Compare local date-time ordering inclusively
@input First local date-time
@input Second local date-time
@result True when first is not later
]])
tempus.mtLocalDateTime.__le = function(A:table, B:table):bool
   return A < B or A is B
end

@Doc(text=[[
@desc Return the instant represented by this value
@result Instant value
]])
function tempus.mtOffsetDateTime:instant():table
   return offset_date_time_instant(self)
end

@Doc(text=[[
@desc Return the offset
@result Offset value
]])
function tempus.mtOffsetDateTime:offset():table
   return require_offset_date_time(self).offset
end

@Doc(text=[[
@desc Return the local date
@result LocalDate value
]])
function tempus.mtOffsetDateTime:date():table
   return require_offset_date_time(self).local_date_time:date()
end

@Doc(text=[[
@desc Return the local time
@result LocalTime value
]])
function tempus.mtOffsetDateTime:time():table
   return require_offset_date_time(self).local_date_time:time()
end

@Doc(text=[[
@desc Return the local date-time
@result LocalDateTime value
]])
function tempus.mtOffsetDateTime:localDateTime():table
   return require_offset_date_time(self).local_date_time
end

@Doc(text=[[
@desc Format this offset date-time
@input Format pattern
@result Formatted text
]])
function tempus.mtOffsetDateTime:format(Pattern:any):str
   fields = require_offset_date_time(self)
   date_fields, time_fields = local_date_time_parts(fields.local_date_time)
   return format_local_fields('OffsetDateTime', date_fields, time_fields, fields.offset, nil, Pattern)
end

@Doc(text=[[
@desc Convert this value to a zoned date-time
@input Target time zone
@result ZonedDateTime value
]])
function tempus.mtOffsetDateTime:toZonedDateTime(Zone:table):table
   return new_zoned_date_time(offset_date_time_instant(self), Zone)
end

@Doc(text=[[
@desc Compare by represented instant
@input Instant or OffsetDateTime value
@result True when instants match
]])
function tempus.mtOffsetDateTime:instantEquals(Other:table):bool
   if tempus.isInstant(Other) then return self:instant() is Other end
   if tempus.isOffsetDateTime(Other) then return self:instant() is Other:instant() end
   tempus._invalidValue('Other must be an Instant or OffsetDateTime value.')
end

@Doc(text=[[
@desc Convert this offset date-time to text
@result ISO offset date-time text
]])
tempus.mtOffsetDateTime.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'OffsetDateTime')
   return tostring(fields.local_date_time) .. tostring(fields.offset)
end

@Doc(text=[[
@desc Compare offset date-times for equality
@input First offset date-time
@input Second offset date-time
@result True when equal
]])
tempus.mtOffsetDateTime.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'OffsetDateTime')
   b = tempus._fields(B, 'OffsetDateTime')
   return offset_date_time_instant(A) is offset_date_time_instant(B) and a.offset is b.offset
end

@Doc(text=[[
@desc Compare offset date-time ordering
@input First offset date-time
@input Second offset date-time
@result True when first is earlier
]])
tempus.mtOffsetDateTime.__lt = function(A:table, B:table):bool
   return offset_date_time_instant(A) < offset_date_time_instant(B)
end

@Doc(text=[[
@desc Compare offset date-time ordering inclusively
@input First offset date-time
@input Second offset date-time
@result True when first is not later
]])
tempus.mtOffsetDateTime.__le = function(A:table, B:table):bool
   return offset_date_time_instant(A) <= offset_date_time_instant(B)
end

@Doc(text=[[
@desc Add a duration or period
@input OffsetDateTime value
@input Duration or Period value
@result OffsetDateTime value
]])
tempus.mtOffsetDateTime.__add = function(A:table, B:table):table
   fields = tempus._fields(A, 'OffsetDateTime')
   if tempus.isDuration(B) then
      return offset_date_time_from_instant(offset_date_time_instant(A) + B, fields.offset)
   end
   if tempus.isPeriod(B) then return new_offset_date_time(fields.local_date_time + B, fields.offset) end
   unsupported_operation(A, '+', B)
end

@Doc(text=[[
@desc Subtract a duration, period, or offset date-time
@input OffsetDateTime value
@input Duration, Period, or OffsetDateTime value
@result OffsetDateTime or Duration value
]])
tempus.mtOffsetDateTime.__sub = function(A:table, B:table):table
   fields = tempus._fields(A, 'OffsetDateTime')
   if tempus.isDuration(B) then
      return offset_date_time_from_instant(offset_date_time_instant(A) - B, fields.offset)
   end
   if tempus.isPeriod(B) then return new_offset_date_time(fields.local_date_time - B, fields.offset) end
   if tempus.isOffsetDateTime(B) then return offset_date_time_instant(A) - offset_date_time_instant(B) end
   unsupported_operation(A, '-', B)
end

@Doc(text=[[
@desc Return the represented instant
@result Instant value
]])
function tempus.mtZonedDateTime:instant():table
   return require_zoned_date_time(self).instant
end

@Doc(text=[[
@desc Return the time zone
@result Zone value
]])
function tempus.mtZonedDateTime:zone():table
   return require_zoned_date_time(self).zone
end

@Doc(text=[[
@desc Return the offset at this instant
@result Offset value
]])
function tempus.mtZonedDateTime:offset():table
   fields = require_zoned_date_time(self)
   return fields.zone:offsetAt(fields.instant)
end

@Doc(text=[[
@desc Return the local date-time
@result LocalDateTime value
]])
function tempus.mtZonedDateTime:localDateTime():table
   fields = require_zoned_date_time(self)
   return local_date_time_from_instant_in_zone(fields.instant, fields.zone)
end

@Doc(text=[[
@desc Return the local date
@result LocalDate value
]])
function tempus.mtZonedDateTime:date():table
   return self:localDateTime():date()
end

@Doc(text=[[
@desc Return the local time
@result LocalTime value
]])
function tempus.mtZonedDateTime:time():table
   return self:localDateTime():time()
end

@Doc(text=[[
@desc Change zone while preserving the instant
@input Target time zone
@result ZonedDateTime value
]])
function tempus.mtZonedDateTime:withZoneSameInstant(Zone:table):table
   return new_zoned_date_time(require_zoned_date_time(self).instant, Zone)
end

@Doc(text=[[
@desc Change zone while preserving local fields
@input Target time zone
@input Resolver value
@result ZonedDateTime value
]])
function tempus.mtZonedDateTime:withZoneSameLocal(Zone:table, Resolver:table):table
   Resolver ??= tempus.resolve.compatible
   return self:localDateTime():toZonedDateTime(Zone, Resolver)
end

@Doc(text=[[
@desc Return a zoned date-time with replacement local fields
@input Table with replacement local fields
@result ZonedDateTime value
]])
zoned_date_time_with_local = function(Self:table, KV:table):table
   tempus._requireTable('fields', KV)
   fields = require_zoned_date_time(Self)
   resolver = KV.resolver ?? tempus.resolve.compatible
   return Self:localDateTime():withFields(KV):toZonedDateTime(fields.zone, resolver)
end

tempus.mtZonedDateTime.withLocal = zoned_date_time_with_local

@Doc(text=[[
@desc Convert this value to an offset date-time
@result OffsetDateTime value
]])
function tempus.mtZonedDateTime:toOffsetDateTime():table
   return new_offset_date_time(self:localDateTime(), self:offset())
end

@Doc(text=[[
@desc Format this zoned date-time
@input Format pattern
@result Formatted text
]])
function tempus.mtZonedDateTime:format(Pattern:any):str
   fields = require_zoned_date_time(self)
   date_fields, time_fields = local_date_time_parts(self:localDateTime())
   return format_local_fields('ZonedDateTime', date_fields, time_fields, self:offset(), fields.zone:id(), Pattern)
end

@Doc(text=[[
@desc Compare by represented instant
@input Instant, OffsetDateTime, or ZonedDateTime value
@result True when instants match
]])
function tempus.mtZonedDateTime:instantEquals(Other:table):bool
   fields = require_zoned_date_time(self)
   if tempus.isInstant(Other) then return fields.instant is Other end
   if tempus.isOffsetDateTime(Other) then return fields.instant is Other:instant() end
   if tempus.isZonedDateTime(Other) then return fields.instant is Other:instant() end
   tempus._invalidValue('Other must be an Instant, OffsetDateTime, or ZonedDateTime value.')
end

@Doc(text=[[
@desc Convert this zoned date-time to text
@result ISO zoned date-time text
]])
tempus.mtZonedDateTime.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'ZonedDateTime')
   return tostring(Self:localDateTime()) .. tostring(Self:offset()) .. '[' .. fields.zone:id() .. ']'
end

@Doc(text=[[
@desc Compare zoned date-times for equality
@input First zoned date-time
@input Second zoned date-time
@result True when equal
]])
tempus.mtZonedDateTime.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'ZonedDateTime')
   b = tempus._fields(B, 'ZonedDateTime')
   return a.instant is b.instant and a.zone is b.zone
end

@Doc(text=[[
@desc Compare zoned date-time ordering
@input First zoned date-time
@input Second zoned date-time
@result True when first is earlier
]])
tempus.mtZonedDateTime.__lt = function(A:table, B:table):bool
   return tempus._fields(A, 'ZonedDateTime').instant < tempus._fields(B, 'ZonedDateTime').instant
end

@Doc(text=[[
@desc Compare zoned date-time ordering inclusively
@input First zoned date-time
@input Second zoned date-time
@result True when first is not later
]])
tempus.mtZonedDateTime.__le = function(A:table, B:table):bool
   return tempus._fields(A, 'ZonedDateTime').instant <= tempus._fields(B, 'ZonedDateTime').instant
end

@Doc(text=[[
@desc Add a duration or period
@input ZonedDateTime value
@input Duration or Period value
@result ZonedDateTime value
]])
tempus.mtZonedDateTime.__add = function(A:table, B:table):table
   fields = tempus._fields(A, 'ZonedDateTime')
   if tempus.isDuration(B) then return new_zoned_date_time(fields.instant + B, fields.zone) end
   if tempus.isPeriod(B) then return (A:localDateTime() + B):toZonedDateTime(fields.zone) end
   unsupported_operation(A, '+', B)
end

@Doc(text=[[
@desc Subtract a duration, period, or zoned date-time
@input ZonedDateTime value
@input Duration, Period, or ZonedDateTime value
@result ZonedDateTime or Duration value
]])
tempus.mtZonedDateTime.__sub = function(A:table, B:table):table
   fields = tempus._fields(A, 'ZonedDateTime')
   if tempus.isDuration(B) then return new_zoned_date_time(fields.instant - B, fields.zone) end
   if tempus.isPeriod(B) then return (A:localDateTime() - B):toZonedDateTime(fields.zone) end
   if tempus.isZonedDateTime(B) then return fields.instant - B:instant() end
   unsupported_operation(A, '-', B)
end

@Doc(text=[[
@desc Normalise months and weeks
@result Period value
]])
function tempus.mtPeriod:normalise():table
   fields = tempus._fields(self, 'Period')
   total_months = fields.years * 12 + fields.months
   years = math.floor(total_months / 12)
   months = total_months - years * 12
   return new_period(years, months, 0, fields.weeks * 7 + fields.days)
end

@Doc(text=[[
@desc Convert this period to text
@result ISO period text
]])
tempus.mtPeriod.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'Period')
   text = 'P'
   if fields.years != 0 then text ..= tostring(fields.years) .. 'Y' end
   if fields.months != 0 then text ..= tostring(fields.months) .. 'M' end
   if fields.weeks != 0 then text ..= tostring(fields.weeks) .. 'W' end
   if fields.days != 0 then text ..= tostring(fields.days) .. 'D' end
   if text is 'P' then text ..= '0D' end
   return text
end

@Doc(text=[[
@desc Compare periods for equality
@input First period
@input Second period
@result True when equal
]])
tempus.mtPeriod.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'Period')
   b = tempus._fields(B, 'Period')
   return a.years is b.years and a.months is b.months and a.weeks is b.weeks and a.days is b.days
end

@Doc(text=[[
@desc Add two periods
@input First period
@input Second period
@result Period value
]])
tempus.mtPeriod.__add = function(A:table, B:table):table
   a = tempus._fields(A, 'Period')
   if tempus.isPeriod(B) then
      b = tempus._fields(B, 'Period')
      return new_period(a.years + b.years, a.months + b.months, a.weeks + b.weeks, a.days + b.days)
   end
   unsupported_operation(A, '+', B)
end

@Doc(text=[[
@desc Subtract two periods
@input First period
@input Second period
@result Period value
]])
tempus.mtPeriod.__sub = function(A:table, B:table):table
   a = tempus._fields(A, 'Period')
   if tempus.isPeriod(B) then
      b = tempus._fields(B, 'Period')
      return new_period(a.years - b.years, a.months - b.months, a.weeks - b.weeks, a.days - b.days)
   end
   unsupported_operation(A, '-', B)
end

@Doc(text=[[
@desc Negate this period
@result Period value
]])
tempus.mtPeriod.__unm = function(Self:table):table
   fields = tempus._fields(Self, 'Period')
   return new_period(-fields.years, -fields.months, -fields.weeks, -fields.days)
end

@Doc(text=[[
@desc Return the start instant
@result Instant value
]])
function tempus.mtInterval:start():table
   return tempus._fields(self, 'Interval').start
end

@Doc(text=[[
@desc Return the stop instant
@result Instant value
]])
function tempus.mtInterval:stop():table
   return tempus._fields(self, 'Interval').stop
end

@Doc(text=[[
@desc Return the interval duration
@result Duration value
]])
function tempus.mtInterval:duration():table
   fields = tempus._fields(self, 'Interval')
   return fields.stop - fields.start
end

@Doc(text=[[
@desc Check if an instant is inside this interval
@input Instant value
@result True when contained
]])
function tempus.mtInterval:contains(Instant:table):bool
   if not tempus.isInstant(Instant) then tempus._invalidValue('Instant must be an Instant value.') end
   fields = tempus._fields(self, 'Interval')
   return fields.start <= Instant and Instant < fields.stop
end

@Doc(text=[[
@desc Check if two intervals overlap
@input Other interval
@result True when intervals overlap
]])
function tempus.mtInterval:overlaps(Other:table):bool
   if not tempus.isInterval(Other) then tempus._invalidValue('Other must be an Interval value.') end
   fields = tempus._fields(self, 'Interval')
   other = tempus._fields(Other, 'Interval')
   return fields.start < other.stop and other.start < fields.stop
end

@Doc(text=[[
@desc Return the overlapping interval
@input Other interval
@result Intersection interval
]])
function tempus.mtInterval:intersection(Other:table):table
   if not tempus.isInterval(Other) then tempus._invalidValue('Other must be an Interval value.') end
   fields = tempus._fields(self, 'Interval')
   other = tempus._fields(Other, 'Interval')
   start = fields.start < other.start ? other.start :> fields.start
   stop = fields.stop < other.stop ? fields.stop :> other.stop
   if stop < start then stop = start end
   return new_interval(start, stop)
end

@Doc(text=[[
@desc Return the combined interval
@input Overlapping interval
@result Union interval
]])
function tempus.mtInterval:union(Other:table):table
   if not tempus.isInterval(Other) then tempus._invalidValue('Other must be an Interval value.') end
   fields = tempus._fields(self, 'Interval')
   other = tempus._fields(Other, 'Interval')
   if fields.stop < other.start or other.stop < fields.start then
      tempus._invalidValue('Cannot union separate intervals.')
   end

   start = fields.start < other.start ? fields.start :> other.start
   stop = fields.stop < other.stop ? other.stop :> fields.stop
   return new_interval(start, stop)
end

@Doc(text=[[
@desc Check if this interval is empty
@result True for an empty interval
]])
function tempus.mtInterval:isEmpty():bool
   fields = tempus._fields(self, 'Interval')
   return fields.start is fields.stop
end

@Doc(text=[[
@desc Convert this interval to text
@result Interval text
]])
tempus.mtInterval.__tostring = function(Self:table):str
   fields = tempus._fields(Self, 'Interval')
   return f'{fields.start}/{fields.stop}'
end

@Doc(text=[[
@desc Compare intervals for equality
@input First interval
@input Second interval
@result True when equal
]])
tempus.mtInterval.__eq = function(A:table, B:table):bool
   a = tempus._fields(A, 'Interval')
   b = tempus._fields(B, 'Interval')
   return a.start is b.start and a.stop is b.stop
end

@Doc(text=[[
@desc Return the canonical zone ID
@result Zone ID
]])
function tempus.mtZone:id():str
   return tempus._fields(self, 'Zone').id
end

@Doc(text=[[
@desc Return the native zone ID
@result Native zone ID
]])
function tempus.mtZone:nativeId():str
   return tempus._fields(self, 'Zone').native_id
end

@Doc(text=[[
@desc Return the zone data source
@result Source name
]])
function tempus.mtZone:source():str
   return tempus._fields(self, 'Zone').source
end

@Doc(text=[[
@desc Check if fallback zone data is used
@result True when fallback data is used
]])
function tempus.mtZone:isFallback():bool
   return tempus._fields(self, 'Zone').is_fallback
end

@Doc(text=[[
@desc Return the offset at an instant
@input Instant value
@result Offset value
]])
function tempus.mtZone:offsetAt(Instant:table):table
   require_instant(Instant)
   fields = tempus._fields(self, 'Zone')
   info = zone_info_for_instant(fields, Instant, 1, 0)
   return transition_offset_at(info, Instant)
end

@Doc(text=[[
@desc Return the zone name at an instant
@input Instant value
@result Zone name
]])
function tempus.mtZone:nameAt(Instant:table):str
   require_instant(Instant)
   fields = tempus._fields(self, 'Zone')
   info = zone_info_for_instant(fields, Instant, 1, 0)
   return transition_name_at(info, Instant)
end

@Doc(text=[[
@desc Return the next zone transition
@input Instant value
@result Next transition instant, or nil
]])
function tempus.mtZone:nextTransition(Instant:table):any
   require_instant(Instant)
   fields = tempus._fields(self, 'Zone')
   info = zone_info_for_instant(fields, Instant, 0, 1)
   for transition in values(info.transitions) do
      if compare_instants(Instant, transition.instant) < 0 then return transition.instant end
   end
   return nil
end

@Doc(text=[[
@desc Return the previous zone transition
@input Instant value
@result Previous transition instant, or nil
]])
function tempus.mtZone:previousTransition(Instant:table):any
   require_instant(Instant)
   fields = tempus._fields(self, 'Zone')
   info = zone_info_for_instant(fields, Instant, 1, 0)
   previous = nil
   for transition in values(info.transitions) do
      if compare_instants(transition.instant, Instant) < 0 then previous = transition.instant
      else break end
   end
   return previous
end

@Doc(text=[[
@desc Convert this zone to text
@result Zone ID
]])
tempus.mtZone.__tostring = function(Self:table):str
   return tempus._fields(Self, 'Zone').id
end

@Doc(text=[[
@desc Compare zones for equality
@input First zone
@input Second zone
@result True when equal
]])
tempus.mtZone.__eq = function(A:table, B:table):bool
   return tempus._fields(A, 'Zone').id is tempus._fields(B, 'Zone').id
end

@Doc(text=[[
@desc Return the clock instant
@result Instant value
]])
function tempus.mtClock:instant():table
   fields = tempus._fields(self, 'Clock')

   if fields.kind is 'fixed' then return fields.instant end
   if fields.kind is 'offset' then return fields.base_clock:instant() + fields.offset end
   if fields.kind is 'system' then
      time_obj = obj.new('time')
      check time_obj.acQuery() -- Get epoch time
      return instant_from_system_micros(time_obj.systemTime)
   end

   tempus._invalidValue(f"Unknown Clock kind '{fields.kind}'.")
end

@Doc(text=[[
@desc Return today's date for a zone
@input Time zone
@result LocalDate value
]])
function tempus.mtClock:today(Zone:table):table
   return self:localDateTime(Zone):date()
end

@Doc(text=[[
@desc Return the clock local date-time for a zone
@input Time zone
@result LocalDateTime value
]])
function tempus.mtClock:localDateTime(Zone:table):table
   Zone ??= tempus.zone.local()
   require_zone(Zone)

   instant = self:instant()
   instant_fields = tempus._fields(instant, 'Instant')
   offset_fields = tempus._fields(Zone:offsetAt(instant), 'Offset')
   date_fields, time_fields = epoch_second_to_local(instant_fields.epoch_second + offset_fields.seconds,
      instant_fields.nano)
   return new_local_date_time(date_fields.year, date_fields.month, date_fields.day, time_fields.hour,
      time_fields.minute, time_fields.second, time_fields.nano)
end

@Doc(text=[[
@desc Return the clock zoned date-time
@input Time zone
@result ZonedDateTime value
]])
function tempus.mtClock:zonedDateTime(Zone:table):table
   Zone ??= tempus.zone.local()
   return new_zoned_date_time(self:instant(), Zone)
end

@Doc(text=[[
@desc Convert this clock to text
@result Clock description
]])
tempus.mtClock.__tostring = function(Self:table):str
   return f"tempus.Clock({tempus._fields(Self, 'Clock').kind})"
end

----------------------------------------------------------------------------------------------------------------------
-- Zone, clock, and resolver public API

tempus.zone = make_constructor('zone')

@Doc(text=[[
@desc Return the local time zone
@result Zone value
]])
tempus.zone.local = function():table
   return new_zone(nil)
end

@Doc(text=[[
@desc Return the UTC time zone
@result Zone value
]])
tempus.zone.utc = function():table
   return new_zone('UTC')
end

@Doc(text=[[
@desc Create a time zone
@input Zone ID, or nil for local
@result Zone value
]])
getmetatable(tempus.zone).__call = function(Self, ZoneID:any):table
   return new_zone(ZoneID)
end

tempus.zonedDateTime = make_constructor('zonedDateTime')

@Doc(text=[[
@desc Create a zoned date-time from field values
@input Table with instant and zone, or local_date_time and zone
@result ZonedDateTime value
]])
tempus.zonedDateTime.from = function(KV:table):table
   tempus._requireTable('zonedDateTime', KV)
   if KV.instant != nil then return new_zoned_date_time(KV.instant, KV.zone) end
   if KV.local_date_time != nil then
      return KV.local_date_time:toZonedDateTime(KV.zone, KV.resolver ?? tempus.resolve.compatible)
   end
   tempus._invalidValue('zonedDateTime.from requires instant or local_date_time.')
end

@Doc(text=[[
@desc Parse an ISO zoned date-time
@input Zoned date-time text
@result ZonedDateTime value
]])
tempus.zonedDateTime.parse = function(Text:str):table
   if type(Text) != 'string' then tempus._syntaxError('ZonedDateTime text must be a string.') end

   offset_text, zone_text = rx_zoned_date_time.extract(Text)
   if offset_text is nil then tempus._syntaxError(f"Invalid ZonedDateTime string '{Text}'.") end

   offset_date_time = tempus.offsetDateTime.parse(offset_text)
   return new_zoned_date_time(offset_date_time:instant(), tempus.zone(zone_text))
end

@Doc(text=[[
@desc Create a zoned date-time
@input Instant value
@input Zone value
@result ZonedDateTime value
]])
getmetatable(tempus.zonedDateTime).__call = function(Self, Instant:any, Zone:any):table
   return new_zoned_date_time(Instant, Zone)
end

tempus.clock = {}

@Doc(text=[[
@desc Create a system clock
@result Clock value
]])
tempus.clock.system = function():table
   return new_clock('system', {})
end

@Doc(text=[[
@desc Create a fixed clock
@input Fixed instant
@result Clock value
]])
tempus.clock.fixed = function(Instant:table):table
   require_instant(Instant)
   return new_clock('fixed', { instant = Instant })
end

@Doc(text=[[
@desc Create a clock offset from another clock
@input Base clock
@input Offset duration
@result Clock value
]])
tempus.clock.offset = function(BaseClock:table, Duration:table):table
   require_clock(BaseClock)
   require_duration(Duration)
   return new_clock('offset', { base_clock = BaseClock, offset = Duration })
end

tempus.resolve = {
   reject = tempus._makeValue('Resolver', { name = 'reject' }),
   earlier = tempus._makeValue('Resolver', { name = 'earlier' }),
   later = tempus._makeValue('Resolver', { name = 'later' }),
   skip = tempus._makeValue('Resolver', { name = 'skip' }),
   compatible = tempus._makeValue('Resolver', { name = 'compatible' })
}

@Doc(text=[[
@desc Return the current instant
@input Clock to query
@result Instant value
]])
tempus.now = function(Clock:table):table
   Clock ??= tempus.clock.system()
   require_clock(Clock)
   return Clock:instant()
end

@Doc(text=[[
@desc Return today's date
@input Time zone
@input Clock to query
@result LocalDate value
]])
tempus.today = function(Zone:table, Clock:table):table
   Zone ??= tempus.zone.local()
   Clock ??= tempus.clock.system()
   require_zone(Zone)
   require_clock(Clock)
   return Clock:today(Zone)
end

